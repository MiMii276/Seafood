{% extends 'base.html.twig' %}

{% block title %}Create New User — Seafoodie{% endblock %}

{% block stylesheets %}
{{ parent() }}
<style>
    * { margin: 0; padding: 0; box-sizing: border-box; }

    /* Hide footer on this page */
    .footer {
        display: none !important;
    }

    .create-wrapper {
        min-height: 90vh;
        display: flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(135deg, var(--teal-deep) 0%, var(--teal-mid) 100%);
        padding: 2rem 1rem;
        position: relative;
        overflow: hidden;
    }

    /* Decorative orbs matching dashboard */
    .create-orb {
        position: absolute;
        border-radius: 50%;
        pointer-events: none;
        opacity: 0.08;
    }
    .create-orb-1 {
        width: 500px;
        height: 500px;
        background: var(--teal-bright);
        top: -150px;
        left: -100px;
    }
    .create-orb-2 {
        width: 380px;
        height: 380px;
        background: var(--amber);
        bottom: -80px;
        right: -60px;
    }
    .create-orb-3 {
        width: 220px;
        height: 220px;
        background: var(--teal-bright);
        bottom: 30%;
        left: 15%;
        opacity: 0.05;
    }

    /* Main Card */
    .page-card {
        background: #fff;
        border-radius: 32px;
        padding: 2rem 2rem 1.8rem;
        max-width: 560px;
        width: 100%;
        box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25);
        position: relative;
        z-index: 2;
        transition: transform 0.3s ease, box-shadow 0.3s ease;
        animation: fadeInUp 0.5s ease forwards;
    }

    @keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(30px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .page-card:hover {
        transform: translateY(-6px);
        box-shadow: 0 30px 55px -15px rgba(0, 0, 0, 0.3);
    }

    /* Header Section */
    .card-header {
        text-align: center;
        margin-bottom: 2rem;
    }

    .card-icon {
        width: 80px;
        height: 80px;
        background: linear-gradient(135deg, var(--teal-mid), var(--teal-deep));
        border-radius: 28px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 1.2rem;
        box-shadow: 0 12px 24px rgba(7, 59, 58, 0.25);
        transition: all 0.3s ease;
    }

    .page-card:hover .card-icon {
        transform: scale(1.05);
        border-radius: 24px;
    }

    .card-icon i {
        font-size: 2.2rem;
        color: white;
    }

    .page-card h1 {
        font-family: 'Cormorant Garamond', serif;
        font-size: 2rem;
        font-weight: 700;
        color: var(--ink);
        margin-bottom: 0.25rem;
    }
    .page-card h1 em {
        font-style: italic;
        color: var(--teal-mid);
    }

    .subtitle {
        color: var(--muted);
        font-size: 0.85rem;
        letter-spacing: 0.02em;
        margin-top: 0.25rem;
    }

    .header-accent {
        width: 50px;
        height: 3px;
        background: linear-gradient(90deg, var(--teal-bright), var(--amber));
        border-radius: 3px;
        margin: 0.75rem auto 0;
    }

    /* Form Groups */
    .form-group {
        margin-bottom: 1.35rem;
    }

    .form-label {
        font-weight: 600;
        font-size: 0.75rem;
        letter-spacing: 0.05em;
        text-transform: uppercase;
        color: var(--muted);
        margin-bottom: 0.5rem;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .form-label i {
        color: var(--teal-bright);
        font-size: 0.75rem;
        width: 18px;
    }

    .form-control, .form-select {
        width: 100%;
        padding: 0.75rem 1rem;
        font-size: 0.9rem;
        font-family: 'DM Sans', sans-serif;
        border: 1.5px solid #e2e8f0;
        border-radius: 16px;
        transition: all 0.2s ease;
        background: #fff;
    }

    .form-control:focus, .form-select:focus {
        border-color: var(--teal-bright);
        outline: none;
        box-shadow: 0 0 0 3px rgba(26, 167, 164, 0.1);
    }

    .form-control:hover, .form-select:hover {
        border-color: var(--teal-bright);
    }

    /* Error styling */
    .form-error {
        color: #dc2626;
        font-size: 0.7rem;
        margin-top: 0.4rem;
        display: flex;
        align-items: center;
        gap: 0.4rem;
    }

    .form-error i {
        font-size: 0.65rem;
    }

    .is-invalid {
        border-color: #dc2626 !important;
        background-color: #fef2f2;
    }

    /* Password hint */
    .password-hint {
        font-size: 0.7rem;
        color: var(--muted);
        margin-top: 0.5rem;
        display: flex;
        align-items: center;
        gap: 0.5rem;
        background: var(--cream);
        padding: 0.5rem 0.85rem;
        border-radius: 12px;
    }

    .password-hint i {
        font-size: 0.7rem;
        color: var(--teal-bright);
    }

    /* Alert messages */
    .alert-error {
        background: #fef2f2;
        color: #dc2626;
        padding: 0.85rem 1rem;
        border-radius: 16px;
        font-size: 0.85rem;
        margin-bottom: 1.5rem;
        border-left: 4px solid #dc2626;
        display: flex;
        align-items: center;
        gap: 0.6rem;
    }

    .alert-success {
        background: #ecfdf5;
        color: #065f46;
        padding: 0.85rem 1rem;
        border-radius: 16px;
        font-size: 0.85rem;
        margin-bottom: 1.5rem;
        border-left: 4px solid #10b981;
        display: flex;
        align-items: center;
        gap: 0.6rem;
    }

    /* Role preview (matching dashboard badge style) */
    .role-preview {
        margin-top: 0.75rem;
        padding: 0.75rem 1rem;
        background: var(--cream);
        border-radius: 14px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 0.75rem;
    }

    .role-preview-label {
        font-size: 0.7rem;
        font-weight: 500;
        letter-spacing: 0.05em;
        text-transform: uppercase;
        color: var(--muted);
        display: flex;
        align-items: center;
        gap: 0.4rem;
    }

    .role-badge-demo {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        padding: 0.3rem 0.9rem;
        border-radius: 50px;
        font-size: 0.7rem;
        font-weight: 600;
        letter-spacing: 0.02em;
    }

    .role-badge-demo.admin {
        background: #fee2e2;
        color: #b91c1c;
    }
    .role-badge-demo.admin i {
        color: #b91c1c;
    }

    .role-badge-demo.staff {
        background: #fef3c7;
        color: #d97706;
    }
    .role-badge-demo.staff i {
        color: #d97706;
    }

    .role-badge-demo.user {
        background: #dbeafe;
        color: #2563eb;
    }
    .role-badge-demo.user i {
        color: #2563eb;
    }

    /* Buttons */
    .form-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 14px;
        align-items: center;
        justify-content: center;
        margin-top: 2rem;
        padding-top: 0.5rem;
    }

    .btn-create {
        background: linear-gradient(135deg, var(--teal-deep), var(--teal-mid));
        color: white;
        border: none;
        padding: 0.8rem 2rem;
        border-radius: 50px;
        font-weight: 600;
        font-size: 0.85rem;
        transition: all 0.25s ease;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        gap: 0.6rem;
        flex: 1;
        justify-content: center;
        font-family: 'DM Sans', sans-serif;
        letter-spacing: 0.03em;
    }

    .btn-create:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 20px rgba(7, 59, 58, 0.35);
        background: linear-gradient(135deg, #0a4a49, var(--teal-mid));
    }

    .btn-create:active {
        transform: translateY(0);
    }

    .btn-back {
        background: var(--cream);
        color: var(--teal-deep);
        border: 1.5px solid #e2e8f0;
        padding: 0.8rem 2rem;
        border-radius: 50px;
        font-weight: 600;
        font-size: 0.85rem;
        transition: all 0.25s ease;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 0.6rem;
        flex: 1;
        justify-content: center;
        font-family: 'DM Sans', sans-serif;
    }

    .btn-back:hover {
        background: var(--teal-deep);
        color: white;
        transform: translateY(-2px);
        text-decoration: none;
        border-color: var(--teal-deep);
        box-shadow: 0 8px 20px rgba(7, 59, 58, 0.15);
    }

    /* Responsive */
    @media (max-width: 576px) {
        .page-card {
            padding: 1.5rem;
        }
        .page-card h1 {
            font-size: 1.6rem;
        }
        .form-actions {
            flex-direction: column;
        }
        .btn-create, .btn-back {
            width: 100%;
        }
        .card-icon {
            width: 65px;
            height: 65px;
            border-radius: 22px;
        }
        .card-icon i {
            font-size: 1.8rem;
        }
        .role-preview {
            flex-direction: column;
            align-items: flex-start;
        }
    }
</style>
{% endblock %}

{% block body %}
<div class="create-wrapper">
    <!-- Decorative orbs -->
    <div class="create-orb create-orb-1"></div>
    <div class="create-orb create-orb-2"></div>
    <div class="create-orb create-orb-3"></div>

    <div class="page-card">
        <div class="card-header">
            <div class="card-icon">
                <i class="fas fa-user-plus"></i>
            </div>
            <h1>Create <em>new user</em></h1>
            <div class="header-accent"></div>
            <p class="subtitle">Add a new member to the Seafoodie family</p>
        </div>

        <!-- Flash Messages -->
        {% for message in app.flashes('error') %}
            <div class="alert-error">
                <i class="fas fa-exclamation-triangle"></i>
                <span>{{ message }}</span>
            </div>
        {% endfor %}

        {% for message in app.flashes('success') %}
            <div class="alert-success">
                <i class="fas fa-check-circle"></i>
                <span>{{ message }}</span>
            </div>
        {% endfor %}

        <!-- Form Start -->
        {{ form_start(form, {'attr': {'novalidate': 'novalidate', 'class': 'user-form'}}) }}

        {# Name Field #}
        <div class="form-group">
            <label class="form-label">
                <i class="fas fa-user"></i> Full Name
            </label>
            {{ form_widget(form.name, {'attr': {
                'class': 'form-control',
                'placeholder': 'Enter full name',
                'autofocus': true
            }}) }}
            {{ form_errors(form.name) }}
        </div>

        {# Email Field #}
        <div class="form-group">
            <label class="form-label">
                <i class="fas fa-envelope"></i> Email Address
            </label>
            {{ form_widget(form.email, {'attr': {
                'class': 'form-control',
                'placeholder': 'user@example.com'
            }}) }}
            {{ form_errors(form.email) }}
        </div>

        {# Password Field #}
        <div class="form-group">
            <label class="form-label">
                <i class="fas fa-lock"></i> Password
            </label>
            {{ form_widget(form.plainPassword, {'attr': {
                'class': 'form-control',
                'placeholder': '••••••••'
            }}) }}
            <div class="password-hint">
                <i class="fas fa-info-circle"></i>
                <span>Minimum 6 characters • Use a strong password</span>
            </div>
            {{ form_errors(form.plainPassword) }}
        </div>

        {# Roles Field #}
        <div class="form-group">
            <label class="form-label">
                <i class="fas fa-tag"></i> Assign Role
            </label>
            {{ form_widget(form.roles, {'attr': {
                'class': 'form-select',
                'id': 'roleSelect'
            }}) }}
            
            <!-- Role Preview (matching dashboard badge style) -->
            <div class="role-preview">
                <span class="role-preview-label">
                    <i class="fas fa-eye"></i> Preview:
                </span>
                <span id="rolePreviewBadge" class="role-badge-demo staff">
                    <i class="fas fa-briefcase"></i> Staff
                </span>
            </div>
            {{ form_errors(form.roles) }}
        </div>

        <!-- Form Actions -->
        <div class="form-actions">
            <button type="submit" class="btn-create">
                <i class="fas fa-save"></i> Create User
            </button>
            <a href="{{ path('app_user_index') }}" class="btn-back">
                <i class="fas fa-arrow-left"></i> Back to Users
            </a>
        </div>

        {{ form_end(form) }}
    </div>
</div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
    // Role preview update with dashboard badge styling
    const roleSelect = document.getElementById('roleSelect');
    const rolePreviewBadge = document.getElementById('rolePreviewBadge');
    
    function updateRolePreview() {
        if (roleSelect && rolePreviewBadge) {
            const selectedOption = roleSelect.options[roleSelect.selectedIndex];
            const roleValue = selectedOption.value;
            
            // Remove existing classes
            rolePreviewBadge.classList.remove('admin', 'staff', 'user');
            
            // Add appropriate class and icon
            if (roleValue === 'ROLE_ADMIN') {
                rolePreviewBadge.classList.add('admin');
                rolePreviewBadge.innerHTML = '<i class="fas fa-crown"></i> Admin';
            } else if (roleValue === 'ROLE_STAFF') {
                rolePreviewBadge.classList.add('staff');
                rolePreviewBadge.innerHTML = '<i class="fas fa-briefcase"></i> Staff';
            } else {
                rolePreviewBadge.classList.add('user');
                rolePreviewBadge.innerHTML = '<i class="fas fa-user"></i> User';
            }
        }
    }
    
    if (roleSelect) {
        roleSelect.addEventListener('change', updateRolePreview);
        updateRolePreview(); // Initial update
    }
    
    // Add error class styling
    document.querySelectorAll('.form-error').forEach(error => {
        if (error.innerText.trim() !== '') {
            const input = error.previousElementSibling;
            if (input && (input.classList.contains('form-control') || input.classList.contains('form-select'))) {
                input.classList.add('is-invalid');
            }
        }
    });
    
    // Remove invalid class on focus
    document.querySelectorAll('.form-control, .form-select').forEach(input => {
        input.addEventListener('focus', function() {
            this.classList.remove('is-invalid');
        });
    });
</script>
{% endblock %}