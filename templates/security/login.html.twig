{% extends 'base.html.twig' %}

{% block title %}Login — Seafoodie{% endblock %}

{% block stylesheets %}
{{ parent() }}
<style>
    .login-wrapper {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        background: var(--teal-deep);
        padding: 40px 20px;
        position: relative;
        overflow: hidden;
    }

    /* Background orbs */
    .login-orb {
        position: absolute;
        border-radius: 50%;
        pointer-events: none;
        opacity: 0.07;
    }
    .login-orb-1 { width: 480px; height: 480px; background: var(--teal-bright); top: -140px; left: -100px; }
    .login-orb-2 { width: 320px; height: 320px; background: var(--amber);       bottom: -80px; right: -80px; }
    .login-orb-3 { width: 180px; height: 180px; background: var(--teal-bright); bottom: 120px; left: 10%;  opacity: 0.04; }

    /* Accent top line */
    .login-wrapper::before {
        content: '';
        position: absolute;
        top: 0; left: 0; right: 0;
        height: 4px;
        background: linear-gradient(90deg, var(--teal-bright), var(--amber), var(--teal-bright));
    }

    .login-container {
        width: 100%;
        max-width: 460px;
        position: relative;
        animation: slideUp 0.55s ease;
    }

    @keyframes slideUp {
        from { opacity: 0; transform: translateY(28px); }
        to   { opacity: 1; transform: translateY(0); }
    }

    /* Card */
    .login-card {
        background: #fff;
        border-radius: 28px;
        padding: 44px 40px 36px;
        box-shadow: 0 32px 64px rgba(0,0,0,0.22);
    }

    /* Header */
    .login-header { text-align: center; margin-bottom: 32px; }

    .login-monogram {
        width: 64px; height: 64px;
        background: var(--teal-light);
        border-radius: 20px;
        display: inline-flex; align-items: center; justify-content: center;
        margin-bottom: 18px;
    }
    .login-monogram svg { width: 30px; height: 30px; stroke: var(--teal-mid); stroke-width: 1.7; fill: none; }

    .login-header h2 {
        font-family: 'Cormorant Garamond', serif;
        font-size: 2rem;
        font-weight: 700;
        color: var(--ink);
        margin-bottom: 6px;
        line-height: 1.1;
    }
    .login-header h2 em { font-style: italic; color: var(--teal-mid); }
    .login-header p {
        font-size: 13px;
        color: var(--muted);
        font-weight: 300;
    }

    /* Error alert */
    .alert-error {
        background: #fff5f5;
        border: 1px solid #fed7d7;
        border-left: 3px solid #e53e3e;
        border-radius: 12px;
        padding: 13px 16px;
        margin-bottom: 24px;
        display: flex;
        align-items: center;
        gap: 10px;
        font-size: 13px;
        color: #c53030;
    }
    .alert-error i { flex-shrink: 0; }

    /* Form */
    .sf-form-group { margin-bottom: 20px; }

    .sf-label {
        display: block;
        font-size: 11px;
        font-weight: 500;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: var(--ink);
        margin-bottom: 8px;
    }

    .sf-input-wrap { position: relative; }
    .sf-input-wrap i {
        position: absolute;
        left: 16px; top: 50%;
        transform: translateY(-50%);
        color: var(--muted);
        font-size: 13px;
        pointer-events: none;
    }

    .sf-input {
        width: 100%;
        padding: 13px 16px 13px 42px;
        background: var(--cream);
        border: 1.5px solid rgba(0,0,0,0.08);
        border-radius: 12px;
        font-family: 'DM Sans', sans-serif;
        font-size: 14px;
        color: var(--ink);
        outline: none;
        transition: border-color 0.2s, box-shadow 0.2s;
    }
    .sf-input::placeholder { color: var(--muted); opacity: 0.6; }
    .sf-input:focus {
        border-color: var(--teal-mid);
        box-shadow: 0 0 0 3px rgba(13,110,108,0.1);
        background: #fff;
    }

    /* Submit button */
    .btn-signin {
        width: 100%;
        padding: 14px;
        background: var(--teal-deep);
        color: #fff;
        border: none;
        border-radius: 12px;
        font-family: 'DM Sans', sans-serif;
        font-size: 14px;
        font-weight: 500;
        cursor: pointer;
        transition: background 0.2s, transform 0.2s;
        display: flex; align-items: center; justify-content: center; gap: 8px;
        margin-top: 8px;
    }
    .btn-signin:hover { background: var(--teal-mid); transform: translateY(-2px); }

    /* Divider */
    .sf-divider {
        display: flex; align-items: center; gap: 12px;
        margin: 24px 0;
    }
    .sf-divider-line { flex: 1; height: 1px; background: rgba(0,0,0,0.07); }
    .sf-divider span { font-size: 11px; color: var(--muted); letter-spacing: 0.06em; text-transform: uppercase; white-space: nowrap; }

    /* Google button */
    .btn-google {
        width: 100%;
        padding: 13px;
        background: #fff;
        color: #444;
        border: 1.5px solid rgba(0,0,0,0.1);
        border-radius: 12px;
        font-family: 'DM Sans', sans-serif;
        font-size: 14px;
        font-weight: 400;
        cursor: pointer;
        display: flex; align-items: center; justify-content: center; gap: 10px;
        text-decoration: none;
        transition: border-color 0.2s, box-shadow 0.2s, transform 0.2s;
    }
    .btn-google:hover {
        border-color: #4285f4;
        box-shadow: 0 4px 16px rgba(66,133,244,0.15);
        transform: translateY(-2px);
        color: #444;
        text-decoration: none;
    }
    .btn-google img { width: 18px; height: 18px; }

    /* Card footer */
    .login-card-footer {
        margin-top: 28px;
        padding-top: 24px;
        border-top: 1px solid rgba(0,0,0,0.06);
        text-align: center;
    }
    .login-card-footer p { font-size: 13px; color: var(--muted); margin: 0; }
    .login-card-footer a {
        color: var(--teal-mid);
        font-weight: 500;
        text-decoration: none;
        transition: color 0.2s;
    }
    .login-card-footer a:hover { color: var(--amber); }

    .secure-note {
        font-size: 11px;
        color: var(--muted);
        margin-top: 10px;
        display: flex; align-items: center; justify-content: center; gap: 5px;
        opacity: 0.7;
    }
    .secure-note i { color: var(--teal-bright); font-size: 10px; }

    /* Back to home */
    .back-home {
        text-align: center;
        margin-top: 24px;
    }
    .back-home a {
        display: inline-flex; align-items: center; gap: 7px;
        font-size: 13px;
        color: rgba(255,255,255,0.55);
        text-decoration: none;
        padding: 8px 20px;
        border-radius: 50px;
        border: 1px solid rgba(255,255,255,0.15);
        transition: color 0.2s, border-color 0.2s;
    }
    .back-home a:hover { color: #fff; border-color: rgba(255,255,255,0.35); }

    @media (max-width: 480px) {
        .login-card { padding: 32px 24px 28px; }
        .login-header h2 { font-size: 1.6rem; }
    }
</style>
{% endblock %}

{% block body %}
<div class="login-wrapper">
    <div class="login-orb login-orb-1"></div>
    <div class="login-orb login-orb-2"></div>
    <div class="login-orb login-orb-3"></div>

    <div class="login-container">
        <div class="login-card">

            <!-- Header -->
            <div class="login-header">
                <div class="login-monogram">
                    <svg viewBox="0 0 24 24">
                        <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
                    </svg>
                </div>
                <h2>Welcome <em>back.</em></h2>
                <p>Sign in to your Seafoodie account</p>
            </div>

            <!-- Error -->
            {% if error %}
                <div class="alert-error">
                    <i class="fas fa-exclamation-circle"></i>
                    <span>{{ error.messageKey|trans(error.messageData, 'security') }}</span>
                </div>
            {% endif %}

            <!-- Form -->
            <form method="post" action="{{ path('app_login') }}">
                <div class="sf-form-group">
                    <label class="sf-label" for="username">Email Address</label>
                    <div class="sf-input-wrap">
                        <i class="fas fa-envelope"></i>
                        <input type="email" id="username" name="_username"
                               value="{{ last_username }}"
                               class="sf-input"
                               placeholder="you@example.com"
                               required autofocus>
                    </div>
                </div>

                <div class="sf-form-group">
                    <label class="sf-label" for="password">Password</label>
                    <div class="sf-input-wrap">
                        <i class="fas fa-lock"></i>
                        <input type="password" id="password" name="_password"
                               class="sf-input"
                               placeholder="••••••••"
                               required>
                    </div>
                </div>

                <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">
                <input type="hidden" name="_target_path" value="/dashboard">

                <button type="submit" class="btn-signin">
                    Sign In &nbsp;<i class="fas fa-arrow-right"></i>
                </button>
            </form>

            <!-- Google -->
            <div class="sf-divider">
                <div class="sf-divider-line"></div>
                <span>or continue with</span>
                <div class="sf-divider-line"></div>
            </div>

            <a href="{{ path('connect_google_start') }}" class="btn-google">
                <svg width="18" height="18" viewBox="0 0 48 48">
                    <path fill="#EA4335" d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z"/>
                    <path fill="#4285F4" d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z"/>
                    <path fill="#FBBC05" d="M10.53 28.59c-.48-1.45-.76-2.99-.76-4.59s.27-3.14.76-4.59l-7.98-6.19C.92 16.46 0 20.12 0 24c0 3.88.92 7.54 2.56 10.78l7.97-6.19z"/>
                    <path fill="#34A853" d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.15 1.45-4.92 2.3-8.16 2.3-6.26 0-11.57-4.22-13.47-9.91l-7.98 6.19C6.51 42.62 14.62 48 24 48z"/>
                </svg>
                Sign in with Google
            </a>

            <!-- Footer -->
            <div class="login-card-footer">
                <p>Don't have an account? <a href="{{ path('app_register') }}">Register here</a></p>
                <p class="secure-note">
                    <i class="fas fa-shield-alt"></i> Secure login · 2FA enabled
                </p>
            </div>

        </div>

        <!-- Back to home -->
        <div class="back-home">
            <a href="{{ path('app_home') }}">
                <i class="fas fa-arrow-left"></i> Back to Homepage
            </a>
        </div>
    </div>
</div>
{% endblock %}
