{% extends 'base.html.twig' %}

{% block title %}Dashboard — Seafoodie{% endblock %}

{% block stylesheets %}
{{ parent() }}
<style>
    * { margin: 0; padding: 0; box-sizing: border-box; }

    body { font-family: 'DM Sans', sans-serif; background: var(--cream); }

    /* ── LAYOUT ── */
    .dash-wrapper { min-height: 100vh; display: flex; flex-direction: column; }

    /* ── HEADER ── */
    .dash-header {
        background: var(--teal-deep);
        position: relative;
        overflow: hidden;
    }
    .dash-header::after {
        content: '';
        position: absolute;
        bottom: 0; left: 0; right: 0;
        height: 3px;
        background: linear-gradient(90deg, var(--teal-bright), var(--amber), var(--teal-bright));
        background-size: 200% 100%;
        animation: shimmer 4s ease infinite;
    }
    @keyframes shimmer { 0%,100%{background-position:0%} 50%{background-position:100%} }

    .dash-header-orb {
        position: absolute; border-radius: 50%; pointer-events: none; opacity: 0.06;
    }
    .dash-orb-1 { width: 420px; height: 420px; background: var(--teal-bright); top: -160px; right: -60px; }
    .dash-orb-2 { width: 220px; height: 220px; background: var(--amber); bottom: -80px; left: 10%; }

    .dash-header-inner {
        position: relative; z-index: 2;
        padding: 28px 0 32px;
    }

    .dash-greeting {
        font-family: 'Cormorant Garamond', serif;
        font-size: 2rem;
        font-weight: 700;
        color: #fff;
        line-height: 1.1;
        margin-bottom: 6px;
    }
    .dash-greeting em { font-style: italic; color: var(--amber); }

    .dash-date {
        font-size: 12px;
        color: rgba(255,255,255,0.45);
        letter-spacing: 0.06em;
        display: flex;
        align-items: center;
        gap: 6px;
    }
    .dash-date i { color: var(--teal-bright); font-size: 11px; }

    /* Header mini stats pill */
    .dash-pill-stats {
        display: inline-flex;
        align-items: center;
        gap: 0;
        background: rgba(255,255,255,0.07);
        border: 1px solid rgba(255,255,255,0.12);
        border-radius: 50px;
        overflow: hidden;
    }
    .dash-pill-stat {
        padding: 10px 22px;
        text-align: center;
        border-right: 1px solid rgba(255,255,255,0.1);
    }
    .dash-pill-stat:last-child { border-right: none; }
    .dash-pill-val {
        font-family: 'Cormorant Garamond', serif;
        font-size: 1.5rem;
        font-weight: 700;
        color: #fff;
        line-height: 1;
    }
    .dash-pill-label {
        font-size: 9px;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: rgba(255,255,255,0.4);
        margin-top: 2px;
    }

    /* Profile dropdown */
    .profile-dropdown { position: relative; display: inline-block; }
    .btn-profile {
        display: inline-flex; align-items: center; gap: 8px;
        background: rgba(255,255,255,0.1);
        border: 1px solid rgba(255,255,255,0.15);
        color: #fff;
        padding: 9px 18px;
        border-radius: 50px;
        font-family: 'DM Sans', sans-serif;
        font-size: 13px;
        font-weight: 400;
        cursor: pointer;
        transition: background 0.2s;
    }
    .btn-profile:hover { background: rgba(255,255,255,0.18); }
    .btn-profile-avatar {
        width: 26px; height: 26px; border-radius: 50%;
        background: var(--amber);
        display: flex; align-items: center; justify-content: center;
        font-family: 'Cormorant Garamond', serif;
        font-size: 0.9rem; font-weight: 700;
        color: var(--ink);
    }

    .dropdown-menu-custom {
        position: absolute; top: calc(100% + 8px); right: 0;
        background: #fff;
        border-radius: 16px;
        box-shadow: 0 20px 40px rgba(0,0,0,0.14);
        min-width: 196px;
        opacity: 0; visibility: hidden;
        transform: translateY(-8px);
        transition: all 0.22s ease;
        z-index: 1000;
        overflow: hidden;
    }
    .profile-dropdown:hover .dropdown-menu-custom {
        opacity: 1; visibility: visible; transform: translateY(0);
    }
    .dropdown-item-custom {
        padding: 11px 18px;
        display: flex; align-items: center; gap: 10px;
        font-size: 13px; color: var(--ink);
        text-decoration: none;
        transition: background 0.15s;
        border-bottom: 1px solid rgba(0,0,0,0.04);
    }
    .dropdown-item-custom:last-child { border-bottom: none; }
    .dropdown-item-custom i { color: var(--muted); width: 14px; text-align: center; font-size: 12px; }
    .dropdown-item-custom:hover { background: var(--cream); }
    .dropdown-item-custom.danger { color: #c53030; }
    .dropdown-item-custom.danger i { color: #c53030; }
    .dropdown-item-custom.danger:hover { background: #fff5f5; }
    .dropdown-divider { height: 1px; background: rgba(0,0,0,0.05); }

    /* Website button */
    .btn-website {
        display: inline-flex; align-items: center; gap: 7px;
        background: var(--amber);
        color: var(--ink);
        font-size: 12px; font-weight: 500;
        padding: 9px 18px;
        border-radius: 50px;
        text-decoration: none;
        transition: background 0.2s, transform 0.2s;
    }
    .btn-website:hover { background: #f5b040; transform: translateY(-2px); color: var(--ink); }

    /* ── MAIN CONTENT ── */
    .dash-content { padding: 36px 0 60px; flex: 1; }

    /* ── STAT CARDS ── */
    .stats-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 20px;
        margin-bottom: 28px;
    }

    .stat-card {
        background: #fff;
        border-radius: 22px;
        padding: 26px 24px;
        border: 1px solid rgba(0,0,0,0.05);
        text-decoration: none;
        display: block;
        position: relative;
        overflow: hidden;
        transition: transform 0.25s, box-shadow 0.25s;
        animation: floatIn 0.5s ease forwards;
        opacity: 0;
    }
    .stat-card:nth-child(1) { animation-delay: 0.05s; }
    .stat-card:nth-child(2) { animation-delay: 0.10s; }
    .stat-card:nth-child(3) { animation-delay: 0.15s; }
    .stat-card:nth-child(4) { animation-delay: 0.20s; }

    @keyframes floatIn {
        from { opacity: 0; transform: translateY(20px); }
        to   { opacity: 1; transform: translateY(0); }
    }

    .stat-card:hover { transform: translateY(-6px); box-shadow: 0 20px 40px rgba(7,59,58,0.1); }

    .stat-card-accent {
        position: absolute;
        top: 0; left: 0; right: 0;
        height: 3px;
        border-radius: 22px 22px 0 0;
    }
    .accent-teal   { background: linear-gradient(90deg, var(--teal-mid), var(--teal-bright)); }
    .accent-amber  { background: linear-gradient(90deg, var(--amber), #f5b040); }
    .accent-green  { background: linear-gradient(90deg, #27ae60, #2ecc71); }
    .accent-purple { background: linear-gradient(90deg, #7c3aed, #a78bfa); }

    .stat-icon-wrap {
        width: 50px; height: 50px; border-radius: 14px;
        display: flex; align-items: center; justify-content: center;
        margin-bottom: 18px;
    }
    .icon-teal   { background: var(--teal-light); }
    .icon-amber  { background: #fdf0d5; }
    .icon-green  { background: #d1fae5; }
    .icon-purple { background: #ede9fe; }

    .stat-icon-wrap i { font-size: 1.3rem; }
    .icon-teal i   { color: var(--teal-mid); }
    .icon-amber i  { color: var(--amber); }
    .icon-green i  { color: #059669; }
    .icon-purple i { color: #7c3aed; }

    .stat-num {
        font-family: 'Cormorant Garamond', serif;
        font-size: 2.6rem;
        font-weight: 700;
        color: var(--ink);
        line-height: 1;
        margin-bottom: 4px;
    }
    .stat-lbl {
        font-size: 11px;
        font-weight: 500;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: var(--muted);
    }
    .stat-trend {
        margin-top: 14px;
        display: inline-flex; align-items: center; gap: 5px;
        font-size: 11px; font-weight: 500;
        padding: 4px 10px;
        border-radius: 50px;
    }
    .trend-up   { background: #d1fae5; color: #059669; }
    .trend-blue { background: #dbeafe; color: #2563eb; }
    .trend-amber{ background: #fef3c7; color: #d97706; }
    .trend-teal { background: var(--teal-light); color: var(--teal-mid); }

    .stat-arrow {
        position: absolute; bottom: 20px; right: 20px;
        width: 28px; height: 28px; border-radius: 50%;
        background: var(--cream);
        display: flex; align-items: center; justify-content: center;
        opacity: 0; transition: opacity 0.2s, transform 0.2s;
    }
    .stat-arrow i { font-size: 10px; color: var(--teal-mid); }
    .stat-card:hover .stat-arrow { opacity: 1; transform: translateX(3px); }

    /* ── SECTION CARD ── */
    .dash-card {
        background: #fff;
        border-radius: 22px;
        border: 1px solid rgba(0,0,0,0.05);
        overflow: hidden;
        margin-bottom: 24px;
        animation: floatIn 0.5s ease forwards;
        opacity: 0;
    }
    .dash-card:nth-of-type(1) { animation-delay: 0.25s; }
    .dash-card:nth-of-type(2) { animation-delay: 0.35s; }

    .dash-card-head {
        padding: 20px 28px;
        border-bottom: 1px solid rgba(0,0,0,0.05);
        display: flex; align-items: center; justify-content: space-between;
        gap: 12px;
    }
    .dash-card-title {
        font-family: 'Cormorant Garamond', serif;
        font-size: 1.25rem;
        font-weight: 700;
        color: var(--ink);
        display: flex; align-items: center; gap: 10px;
    }
    .dash-card-title-icon {
        width: 32px; height: 32px; border-radius: 9px;
        background: var(--teal-light);
        display: flex; align-items: center; justify-content: center;
    }
    .dash-card-title-icon i { font-size: 13px; color: var(--teal-mid); }

    .btn-view-all {
        font-size: 12px; font-weight: 500;
        color: var(--teal-mid);
        text-decoration: none;
        display: inline-flex; align-items: center; gap: 5px;
        padding: 6px 14px;
        border-radius: 50px;
        border: 1px solid rgba(13,110,108,0.2);
        transition: background 0.2s, border-color 0.2s;
    }
    .btn-view-all:hover { background: var(--teal-light); border-color: var(--teal-bright); color: var(--teal-mid); }

    /* ── QUICK ACTIONS ── */
    .action-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 16px;
        padding: 24px 28px;
    }
    .action-btn {
        display: flex; align-items: center; justify-content: center; gap: 8px;
        padding: 14px 12px;
        border-radius: 14px;
        font-family: 'DM Sans', sans-serif;
        font-size: 13px; font-weight: 500;
        text-decoration: none;
        border: none; cursor: pointer;
        transition: transform 0.22s, box-shadow 0.22s, filter 0.22s;
        position: relative; overflow: hidden;
    }
    .action-btn:hover { transform: translateY(-4px); box-shadow: 0 12px 24px rgba(0,0,0,0.14); filter: brightness(1.05); }
    .action-btn i { font-size: 14px; }

    .ab-teal   { background: var(--teal-deep); color: #fff; }
    .ab-green  { background: #059669; color: #fff; }
    .ab-blue   { background: #2563eb; color: #fff; }
    .ab-amber  { background: var(--amber); color: var(--ink); }

    /* ── TABLE ── */
    .dash-table { width: 100%; border-collapse: collapse; margin: 0; }
    .dash-table th {
        padding: 14px 28px;
        font-size: 10px; font-weight: 500;
        letter-spacing: 0.12em; text-transform: uppercase;
        color: var(--muted);
        background: var(--cream);
        border-bottom: 1px solid rgba(0,0,0,0.05);
        text-align: left;
    }
    .dash-table td {
        padding: 16px 28px;
        font-size: 13px;
        color: var(--ink);
        border-bottom: 1px solid rgba(0,0,0,0.04);
        vertical-align: middle;
    }
    .dash-table tr:last-child td { border-bottom: none; }
    .dash-table tr:hover td { background: var(--cream); }

    .user-cell { display: flex; align-items: center; gap: 10px; }
    .user-mono {
        width: 34px; height: 34px; border-radius: 10px;
        background: var(--teal-light);
        display: flex; align-items: center; justify-content: center;
        font-family: 'Cormorant Garamond', serif;
        font-size: 1rem; font-weight: 700;
        color: var(--teal-mid); flex-shrink: 0;
    }
    .user-mono-amber { background: #fdf0d5; color: var(--amber); }
    .user-name-main { font-size: 13px; font-weight: 500; color: var(--ink); }
    .user-name-sub  { font-size: 11px; color: var(--muted); }

    /* Badges */
    .sf-badge {
        display: inline-flex; align-items: center; gap: 5px;
        padding: 4px 12px; border-radius: 50px;
        font-size: 11px; font-weight: 500; letter-spacing: 0.04em;
    }
    .badge-admin  { background: #fee2e2; color: #b91c1c; }
    .badge-staff  { background: #fef3c7; color: #d97706; }
    .badge-user   { background: #dbeafe; color: #2563eb; }
    .badge-action { background: var(--cream); color: var(--muted); }

    /* Empty state */
    .empty-state {
        padding: 60px 24px;
        text-align: center;
    }
    .empty-icon {
        width: 64px; height: 64px; border-radius: 20px;
        background: var(--cream);
        display: flex; align-items: center; justify-content: center;
        margin: 0 auto 16px;
    }
    .empty-icon i { font-size: 1.6rem; color: var(--muted); }
    .empty-state h6 { font-size: 15px; font-weight: 500; color: var(--ink); margin-bottom: 4px; }
    .empty-state p  { font-size: 13px; color: var(--muted); font-weight: 300; }

    /* ── RESPONSIVE ── */
    @media (max-width: 992px) {
        .stats-grid { grid-template-columns: repeat(2, 1fr); }
        .action-grid { grid-template-columns: repeat(2, 1fr); }
    }
    @media (max-width: 640px) {
        .stats-grid { grid-template-columns: 1fr; }
        .action-grid { grid-template-columns: 1fr 1fr; }
        .dash-header-inner .d-flex { flex-direction: column; gap: 12px; }
        .dash-greeting { font-size: 1.5rem; }
    }
</style>
{% endblock %}

{% block body %}
<div class="dash-wrapper">

    <!-- HEADER -->
    <div class="dash-header">
        <div class="dash-header-orb dash-orb-1"></div>
        <div class="dash-header-orb dash-orb-2"></div>

        <div class="container">
            <div class="dash-header-inner">
                <div class="d-flex align-items-center justify-content-between flex-wrap gap-3">

                    <!-- Left: greeting -->
                    <div>
                        <h1 class="dash-greeting">
                            Good morning, <em>{{ app.user.name|default(app.user.email)|split('@')[0] }}.</em>
                        </h1>
                        <div class="dash-date">
                            <i class="fas fa-calendar-alt"></i>
                            {{ "now"|date('l, F j, Y') }}
                        </div>
                    </div>

                    <!-- Right: pill stats + actions -->
                    <div class="d-flex align-items-center gap-3 flex-wrap">
                        <div class="dash-pill-stats">
                            <div class="dash-pill-stat">
                                <div class="dash-pill-val">{{ total_users|default(0) }}</div>
                                <div class="dash-pill-label">Users</div>
                            </div>
                            <div class="dash-pill-stat">
                                <div class="dash-pill-val">{{ total_products|default(0) }}</div>
                                <div class="dash-pill-label">Products</div>
                            </div>
                            <div class="dash-pill-stat">
                                <div class="dash-pill-val">{{ total_caterings|default(0) }}</div>
                                <div class="dash-pill-label">Caterings</div>
                            </div>
                        </div>

                        <a href="{{ path('app_home') }}" class="btn-website">
                            <i class="fas fa-globe" style="font-size:11px;"></i> Website
                        </a>

                        <div class="profile-dropdown">
                            <button class="btn-profile">
                                <div class="btn-profile-avatar">
                                    {{ app.user.name|default(app.user.email)|slice(0,1)|upper }}
                                </div>
                                {{ app.user.name|default(app.user.email)|split('@')[0] }}
                                <i class="fas fa-chevron-down" style="font-size:9px;opacity:0.6;"></i>
                            </button>
                            <div class="dropdown-menu-custom">
                                <a href="{{ path('app_profile') }}" class="dropdown-item-custom">
                                    <i class="fas fa-user"></i> My Profile
                                </a>
                                <a href="{{ path('app_user_edit', {id: app.user.id}) }}" class="dropdown-item-custom">
                                    <i class="fas fa-pen"></i> Edit Profile
                                </a>
                                <div class="dropdown-divider"></div>
                                <a href="{{ path('app_logout') }}" class="dropdown-item-custom danger"
                                   onclick="return confirm('Logout?')">
                                    <i class="fas fa-sign-out-alt"></i> Logout
                                </a>
                            </div>
                        </div>
                    </div>

                </div>
            </div>
        </div>
    </div>

    <!-- CONTENT -->
    <div class="dash-content">
        <div class="container">

            <!-- STAT CARDS -->
            <div class="stats-grid">
                <a href="{{ path('app_user_index') }}" class="stat-card">
                    <div class="stat-card-accent accent-teal"></div>
                    <div class="stat-icon-wrap icon-teal">
                        <i class="fas fa-users"></i>
                    </div>
                    <div class="stat-num">{{ total_users|default(0) }}</div>
                    <div class="stat-lbl">Total Users</div>
                    <div class="stat-trend trend-up">
                        <i class="fas fa-chart-line"></i> +12% this month
                    </div>
                    <div class="stat-arrow"><i class="fas fa-arrow-right"></i></div>
                </a>

                <a href="{{ path('app_user_index') }}?role=staff" class="stat-card">
                    <div class="stat-card-accent accent-purple"></div>
                    <div class="stat-icon-wrap icon-purple">
                        <i class="fas fa-user-tie"></i>
                    </div>
                    <div class="stat-num">{{ total_staff|default(0) }}</div>
                    <div class="stat-lbl">Staff Members</div>
                    <div class="stat-trend trend-blue">
                        <i class="fas fa-users"></i> Active team
                    </div>
                    <div class="stat-arrow"><i class="fas fa-arrow-right"></i></div>
                </a>

                <a href="{{ path('app_product_index') }}" class="stat-card">
                    <div class="stat-card-accent accent-green"></div>
                    <div class="stat-icon-wrap icon-green">
                        <i class="fas fa-fish"></i>
                    </div>
                    <div class="stat-num">{{ total_products|default(0) }}</div>
                    <div class="stat-lbl">Total Products</div>
                    <div class="stat-trend trend-teal">
                        <i class="fas fa-plus-circle"></i> Fresh catch
                    </div>
                    <div class="stat-arrow"><i class="fas fa-arrow-right"></i></div>
                </a>

                <a href="{{ path('app_catering_index') }}" class="stat-card">
                    <div class="stat-card-accent accent-amber"></div>
                    <div class="stat-icon-wrap icon-amber">
                        <i class="fas fa-utensils"></i>
                    </div>
                    <div class="stat-num">{{ total_caterings|default(0) }}</div>
                    <div class="stat-lbl">Catering Orders</div>
                    <div class="stat-trend trend-amber">
                        <i class="fas fa-calendar"></i> This month
                    </div>
                    <div class="stat-arrow"><i class="fas fa-arrow-right"></i></div>
                </a>
            </div>

            <!-- QUICK ACTIONS -->
            <div class="dash-card">
                <div class="dash-card-head">
                    <div class="dash-card-title">
                        <div class="dash-card-title-icon">
                            <i class="fas fa-bolt"></i>
                        </div>
                        Quick Actions
                    </div>
                </div>
                <div class="action-grid">
                    <a href="{{ path('app_user_new') }}" class="action-btn ab-teal">
                        <i class="fas fa-user-plus"></i> Add User
                    </a>
                    <a href="{{ path('app_product_new') }}" class="action-btn ab-green">
                        <i class="fas fa-plus-circle"></i> Add Product
                    </a>
                    <a href="{{ path('app_user_index') }}" class="action-btn ab-blue">
                        <i class="fas fa-users-cog"></i> Manage Staff
                    </a>
                    <a href="{{ path('app_activity_log_index') }}" class="action-btn ab-amber">
                        <i class="fas fa-history"></i> View Logs
                    </a>
                </div>
            </div>

            <!-- RECENT ACTIVITY -->
            <div class="dash-card">
                <div class="dash-card-head">
                    <div class="dash-card-title">
                        <div class="dash-card-title-icon">
                            <i class="fas fa-history"></i>
                        </div>
                        Recent Activity
                    </div>
                    <a href="{{ path('app_activity_log_index') }}" class="btn-view-all">
                        View All <i class="fas fa-arrow-right"></i>
                    </a>
                </div>

                <div class="table-responsive">
                    <table class="dash-table">
                        <thead>
                            <tr>
                                <th>User</th>
                                <th>Role</th>
                                <th>Action</th>
                                <th>Time</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for log in recent_logs %}
                                <tr>
                                    <td>
                                        <div class="user-cell">
                                            <div class="user-mono {% if log.role|lower == 'admin' %}user-mono-amber{% endif %}">
                                                {{ log.username|default('?')|slice(0,1)|upper }}
                                            </div>
                                            <div>
                                                <div class="user-name-main">{{ log.username|default('Unknown') }}</div>
                                                <div class="user-name-sub">ID: {{ log.userId }}</div>
                                            </div>
                                        </div>
                                    </td>
                                    <td>
                                        {% set r = log.role|lower %}
                                        {% if r == 'admin' %}
                                            <span class="sf-badge badge-admin"><i class="fas fa-crown"></i> Admin</span>
                                        {% elseif r == 'staff' %}
                                            <span class="sf-badge badge-staff"><i class="fas fa-briefcase"></i> Staff</span>
                                        {% else %}
                                            <span class="sf-badge badge-user"><i class="fas fa-user"></i> {{ log.role }}</span>
                                        {% endif %}
                                    </td>
                                    <td>
                                        <span class="sf-badge badge-action">
                                            {% set a = log.action|lower %}
                                            {% if a == 'login' %}<i class="fas fa-sign-in-alt"></i>
                                            {% elseif a == 'logout' %}<i class="fas fa-sign-out-alt"></i>
                                            {% elseif 'create' in a %}<i class="fas fa-plus-circle"></i>
                                            {% elseif 'update' in a or 'edit' in a %}<i class="fas fa-pen"></i>
                                            {% elseif 'delete' in a %}<i class="fas fa-trash-alt"></i>
                                            {% else %}<i class="fas fa-info-circle"></i>
                                            {% endif %}
                                            {{ log.action|capitalize }}
                                        </span>
                                        {% if log.targetData %}
                                            <div class="user-name-sub mt-1">{{ log.targetData }}</div>
                                        {% endif %}
                                    </td>
                                    <td>
                                        <div class="user-name-main">{{ log.createdAt|date('M d, Y') }}</div>
                                        <div class="user-name-sub">{{ log.createdAt|date('h:i A') }}</div>
                                    </td>
                                </tr>
                            {% else %}
                                <tr>
                                    <td colspan="4">
                                        <div class="empty-state">
                                            <div class="empty-icon"><i class="fas fa-inbox"></i></div>
                                            <h6>No activity yet</h6>
                                            <p>Activity will appear here as users interact with the system.</p>
                                        </div>
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>

        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
// Detect time of day for greeting
(function() {
    const h = new Date().getHours();
    const el = document.querySelector('.dash-greeting');
    if (!el) return;
    const name = el.innerHTML.match(/em>(.*?)<\/em>/)?.[1] || '';
    const greeting = h < 12 ? 'Good morning' : h < 17 ? 'Good afternoon' : 'Good evening';
    el.innerHTML = `${greeting}, <em>${name}</em>.`;
})();
</script>
{% endblock %}
