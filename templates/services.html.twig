{% extends 'base.html.twig' %}

{% block title %}Our Services - Fresh Seafood & Catering{% endblock %}

{% block stylesheets %}
{{ parent() }}
<style>
    * { box-sizing: border-box; }

    :root {
        --teal-deep: #073B3A;
        --teal-mid: #0D6E6C;
        --teal-bright: #1AA7A4;
        --teal-light: #C8EFEE;
        --amber: #E8A030;
        --cream: #FAF8F3;
        --sand: #EFE9D9;
        --ink: #0D1F1E;
        --muted: #556B6A;
    }

    body {
        background: var(--cream);
        font-family: 'DM Sans', sans-serif;
    }

    /* ── PAGE HEADER ── */
    .page-header {
        background: var(--teal-deep);
        color: #fff;
        padding: 120px 40px 60px;
        text-align: center;
        margin-top: -56px;
    }

    .page-header h1 {
        font-family: 'Cormorant Garamond', serif;
        font-size: clamp(2.5rem, 5vw, 4rem);
        font-weight: 700;
        line-height: 1.1;
        margin-bottom: 20px;
    }

    .page-header p {
        font-size: 16px;
        color: rgba(255,255,255,0.7);
        max-width: 600px;
        margin: 0 auto;
    }

    /* ── SECTION SHELL ── */
    .sf-section { padding: 90px 40px; }
    .sf-section-sand { background: var(--sand); }

    .section-tag {
        font-size: 11px;
        font-weight: 500;
        letter-spacing: 0.16em;
        text-transform: uppercase;
        color: var(--teal-bright);
        display: block;
        margin-bottom: 14px;
    }

    .section-h {
        font-family: 'Cormorant Garamond', serif;
        font-size: clamp(2.2rem, 4vw, 3.2rem);
        font-weight: 700;
        color: var(--ink);
        line-height: 1.1;
    }

    .section-h em { font-style: italic; color: var(--teal-mid); }

    .section-lead {
        font-size: 15px;
        color: var(--muted);
        margin-top: 12px;
        font-weight: 300;
        line-height: 1.75;
        max-width: 540px;
    }

    /* ── SERVICES ── */
    .services-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 22px; margin-top: 52px; }
    
    .service-card {
        background: #fff;
        border-radius: 22px;
        padding: 38px 30px;
        border: 1px solid rgba(0,0,0,0.05);
        transition: transform 0.25s, box-shadow 0.25s;
    }
    
    .service-card:hover { transform: translateY(-6px); box-shadow: 0 20px 40px rgba(7,59,58,0.1); }
    
    .svc-icon-wrap {
        width: 58px; height: 58px; border-radius: 16px;
        background: var(--teal-light);
        display: flex; align-items: center; justify-content: center; margin-bottom: 22px;
    }
    
    .svc-icon-wrap svg { width: 26px; height: 26px; stroke: var(--teal-mid); stroke-width: 1.8; fill: none; }
    
    .service-card h4 {
        font-family: 'Cormorant Garamond', serif;
        font-size: 1.5rem;
        font-weight: 700;
        color: var(--ink);
        margin-bottom: 10px;
    }
    
    .service-card p { font-size: 13px; color: var(--muted); line-height: 1.65; font-weight: 300; }

    .service-card.featured {
        background: var(--teal-deep);
        color: #fff;
    }

    .service-card.featured h4 {
        color: #fff;
    }

    .service-card.featured p {
        color: rgba(255,255,255,0.7);
    }

    .service-card.featured .svc-icon-wrap {
        background: rgba(26,167,164,0.2);
    }

    .service-card.featured .svc-icon-wrap svg {
        stroke: var(--amber);
    }

    @media (max-width: 768px) {
        .services-grid { grid-template-columns: 1fr 1fr; }
        .page-header { padding: 80px 24px 40px; }
        .sf-section { padding: 60px 24px; }
    }

    @media (max-width: 480px) {
        .services-grid { grid-template-columns: 1fr; }
    }
</style>
{% endblock %}

{% block body %}

<!-- PAGE HEADER -->
<div class="page-header">
    <h1>Our Services</h1>
    <p>Discover the ways we serve you better</p>
</div>

<!-- SERVICES SECTION -->
<section class="sf-section">
    <span class="section-tag">What We Offer</span>
    <h2 class="section-h">Three ways we<br><em>serve you better.</em></h2>
    
    <div class="services-grid">
        <div class="service-card">
            <div class="svc-icon-wrap">
                <svg viewBox="0 0 24 24"><path d="M3 18l9-9 9 9"/><path d="M12 9V3"/></svg>
            </div>
            <h4>Fresh Catch</h4>
            <p>Daily sourced straight from local fishermen in Dumaguete waters. You get the ocean's best, every morning.</p>
        </div>
        
        <div class="service-card featured">
            <div class="svc-icon-wrap">
                <svg viewBox="0 0 24 24"><rect x="1" y="3" width="15" height="13" rx="1"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
            </div>
            <h4>Fast Delivery</h4>
            <p>Ice-packed and insulated, delivered to your door in under 2 hours. Cold chain guaranteed, always fresh.</p>
        </div>
        
        <div class="service-card">
            <div class="svc-icon-wrap">
                <svg viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
            </div>
            <h4>Catering Services</h4>
            <p>Hosting a party or celebration? We handle bulk seafood orders for events of any size with professional delivery.</p>
        </div>
    </div>
</section>

{% endblock %}
