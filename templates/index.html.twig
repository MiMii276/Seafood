{% extends 'base.html.twig' %}

{% block title %}Fresh Seafood Delivered to Your Door{% endblock %}

{% block stylesheets %}
{{ parent() }}
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;0,700;1,400;1,600&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<style>
    * { box-sizing: border-box; }

    :root {
        --teal-deep: #073B3A;
        --teal-mid: #0D6E6C;
        --teal-bright: #1AA7A4;
        --teal-light: #C8EFEE;
        --amber: #E8A030;
        --amber-light: #FDF0D5;
        --cream: #FAF8F3;
        --sand: #EFE9D9;
        --ink: #0D1F1E;
        --muted: #556B6A;
    }

    body {
        background: var(--cream);
        font-family: 'DM Sans', sans-serif;
        overflow-x: hidden;
    }

    /* ── HERO ── */
    .hero {
        position: relative;
        background: var(--teal-deep);
        min-height: 92vh;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        text-align: center;
        overflow: hidden;
        padding: 80px 40px 100px;
        margin-top: -56px;
    }

    .hero-wave-top {
        position: absolute; top: 0; left: 0; right: 0; height: 5px;
        background: linear-gradient(90deg, var(--teal-bright), var(--amber), var(--teal-bright));
    }

    .hero-orb {
        position: absolute;
        border-radius: 50%;
        opacity: 0.08;
        pointer-events: none;
    }
    .hero-orb-1 { width: 500px; height: 500px; background: var(--teal-bright); top: -120px; left: -80px; }
    .hero-orb-2 { width: 380px; height: 380px; background: var(--amber); bottom: -60px; right: -80px; }
    .hero-orb-3 { width: 200px; height: 200px; background: var(--teal-bright); bottom: 60px; left: 35%; opacity: 0.05; }

    .hero-eyebrow {
        font-size: 11px;
        font-weight: 500;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: var(--teal-bright);
        background: rgba(26,167,164,0.12);
        border: 1px solid rgba(26,167,164,0.3);
        padding: 6px 18px;
        border-radius: 50px;
        margin-bottom: 28px;
        display: inline-block;
        position: relative;
    }

    .hero h1 {
        font-family: 'Cormorant Garamond', serif;
        font-size: clamp(3.2rem, 7vw, 5.5rem);
        font-weight: 700;
        color: #fff;
        line-height: 1.05;
        margin-bottom: 20px;
        position: relative;
    }

    .hero h1 em {
        font-style: italic;
        color: var(--amber);
    }

    .hero-sub {
        font-size: 16px;
        color: rgba(255,255,255,0.6);
        font-weight: 300;
        letter-spacing: 0.02em;
        margin-bottom: 40px;
        position: relative;
    }

    .btn-primary-sf {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        background: var(--amber);
        color: var(--ink);
        font-family: 'DM Sans', sans-serif;
        font-size: 15px;
        font-weight: 500;
        padding: 14px 34px;
        border-radius: 50px;
        text-decoration: none;
        border: none;
        cursor: pointer;
        transition: background 0.2s, transform 0.2s;
    }
    .btn-primary-sf:hover { background: #f5b040; transform: translateY(-2px); color: var(--ink); }

    .btn-ghost-sf {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        background: transparent;
        color: rgba(255,255,255,0.65);
        font-size: 15px;
        font-weight: 400;
        padding: 14px 24px;
        border-radius: 50px;
        text-decoration: none;
        border: 1px solid rgba(255,255,255,0.2);
        margin-left: 12px;
        transition: border-color 0.2s, color 0.2s;
    }
    .btn-ghost-sf:hover { border-color: rgba(255,255,255,0.5); color: #fff; }

    .hero-scroll-indicator {
        position: absolute;
        bottom: 28px;
        left: 50%;
        transform: translateX(-50%);
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 6px;
        opacity: 0.35;
    }
    .scroll-dot {
        width: 4px; height: 4px; border-radius: 50%; background: #fff;
        animation: bounce 1.4s infinite;
    }
    .scroll-dot:nth-child(2) { animation-delay: 0.2s; }
    .scroll-dot:nth-child(3) { animation-delay: 0.4s; }
    @keyframes bounce {
        0%,80%,100% { opacity:0.3; transform:translateY(0); }
        40% { opacity:1; transform:translateY(-5px); }
    }

    /* ── MARQUEE ── */
    .marquee-band {
        background: var(--amber);
        overflow: hidden;
        padding: 11px 0;
        white-space: nowrap;
    }
    .marquee-track {
        display: inline-flex;
        animation: marquee 22s linear infinite;
    }
    .marquee-item {
        display: inline-flex;
        align-items: center;
        gap: 14px;
        padding: 0 36px;
        font-size: 11px;
        font-weight: 500;
        color: var(--ink);
        letter-spacing: 0.1em;
        text-transform: uppercase;
    }
    .marquee-dot { width: 4px; height: 4px; border-radius: 50%; background: rgba(0,0,0,0.3); flex-shrink: 0; }
    @keyframes marquee { from { transform:translateX(0); } to { transform:translateX(-50%); } }

    /* ── SECTION SHELL ── */
    .sf-section { padding: 90px 40px; }
    .sf-section-sm { padding: 60px 40px 90px; }
    .sf-section-sand { background: var(--sand); }
    .sf-section-dark { background: var(--teal-deep); }

    .section-tag {
        font-size: 11px;
        font-weight: 500;
        letter-spacing: 0.16em;
        text-transform: uppercase;
        color: var(--teal-bright);
        display: block;
        margin-bottom: 14px;
    }
    .sf-section-dark .section-tag { color: var(--teal-bright); }

    .section-h {
        font-family: 'Cormorant Garamond', serif;
        font-size: clamp(2.2rem, 4vw, 3.2rem);
        font-weight: 700;
        color: var(--ink);
        line-height: 1.1;
    }
    .section-h em { font-style: italic; color: var(--teal-mid); }
    .sf-section-dark .section-h { color: #fff; }
    .sf-section-dark .section-h em { color: var(--amber); }

    .section-lead {
        font-size: 15px;
        color: var(--muted);
        margin-top: 12px;
        font-weight: 300;
        line-height: 1.75;
        max-width: 540px;
    }
    .sf-section-dark .section-lead { color: rgba(255,255,255,0.5); }

    /* ── ABOUT ── */
    .about-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 70px;
        align-items: center;
        margin-top: 52px;
    }

    .about-checks { margin-top: 30px; display: flex; flex-direction: column; gap: 18px; }
    .check-item { display: flex; align-items: flex-start; gap: 14px; }
    .check-icon {
        width: 24px; height: 24px; border-radius: 50%;
        background: var(--teal-light);
        display: flex; align-items: center; justify-content: center; flex-shrink: 0; margin-top: 1px;
    }
    .check-icon svg { width: 11px; height: 11px; stroke: var(--teal-mid); stroke-width: 2.5; fill: none; }
    .check-title { font-size: 14px; font-weight: 500; color: var(--ink); }
    .check-desc { font-size: 12px; color: var(--muted); margin-top: 2px; font-weight: 300; }

    .stats-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
    .stat-card {
        background: #fff;
        border-radius: 20px;
        padding: 28px 20px;
        border: 1px solid rgba(0,0,0,0.06);
        text-align: center;
    }
    .stat-num {
        font-family: 'Cormorant Garamond', serif;
        font-size: 2.8rem;
        font-weight: 700;
        color: var(--teal-mid);
        line-height: 1;
    }
    .stat-label { font-size: 12px; color: var(--muted); margin-top: 8px; letter-spacing: 0.04em; }

    /* ── OFFER STRIP ── */
    .offer-strip {
        margin: 0 40px;
        border-radius: 28px;
        background: var(--teal-deep);
        padding: 52px 60px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 40px;
        position: relative;
        overflow: hidden;
    }
    .offer-strip::before {
        content: '';
        position: absolute;
        width: 400px; height: 400px;
        border-radius: 50%;
        background: rgba(26,167,164,0.1);
        right: -80px; top: -120px;
        pointer-events: none;
    }
    .offer-pill {
        display: inline-block;
        font-size: 11px;
        font-weight: 500;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        background: rgba(232,160,48,0.15);
        color: var(--amber);
        border: 1px solid rgba(232,160,48,0.3);
        padding: 5px 16px;
        border-radius: 50px;
        margin-bottom: 16px;
    }
    .offer-strip h3 {
        font-family: 'Cormorant Garamond', serif;
        font-size: 2.4rem;
        font-weight: 700;
        color: #fff;
        line-height: 1.15;
    }
    .offer-strip p { font-size: 14px; color: rgba(255,255,255,0.55); margin-top: 10px; font-weight: 300; }
    .offer-btn {
        flex-shrink: 0;
        background: var(--amber);
        color: var(--ink);
        font-family: 'DM Sans', sans-serif;
        font-size: 14px;
        font-weight: 500;
        padding: 15px 32px;
        border-radius: 50px;
        border: none;
        cursor: pointer;
        transition: background 0.2s, transform 0.2s;
        white-space: nowrap;
        text-decoration: none;
        display: inline-block;
    }
    .offer-btn:hover { background: #f5b040; transform: translateY(-2px); color: var(--ink); }

    /* ── SERVICES ── */
    .services-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 22px; margin-top: 52px; }
    .service-card {
        background: #fff;
        border-radius: 22px;
        padding: 38px 30px;
        border: 1px solid rgba(0,0,0,0.05);
        transition: transform 0.25s, box-shadow 0.25s;
    }
    .service-card:hover { transform: translateY(-6px); box-shadow: 0 20px 40px rgba(7,59,58,0.1); }
    .svc-icon-wrap {
        width: 58px; height: 58px; border-radius: 16px;
        background: var(--teal-light);
        display: flex; align-items: center; justify-content: center; margin-bottom: 22px;
    }
    .svc-icon-wrap svg { width: 26px; height: 26px; stroke: var(--teal-mid); stroke-width: 1.8; fill: none; }
    .service-card h4 {
        font-family: 'Cormorant Garamond', serif;
        font-size: 1.5rem;
        font-weight: 700;
        color: var(--ink);
        margin-bottom: 10px;
    }
    .service-card p { font-size: 13px; color: var(--muted); line-height: 1.65; font-weight: 300; }

    /* ── PRODUCTS ── */
    .products-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; margin-top: 52px; }
    .prod-card {
        background: #fff;
        border-radius: 22px;
        overflow: hidden;
        border: 1px solid rgba(0,0,0,0.05);
        transition: transform 0.25s, box-shadow 0.25s;
    }
    .prod-card:hover { transform: translateY(-6px); box-shadow: 0 16px 36px rgba(7,59,58,0.1); }
    .prod-top {
        background: var(--teal-light);
        height: 120px;
        display: flex; align-items: center; justify-content: center;
        font-size: 48px;
        position: relative;
    }
    .prod-badge {
        position: absolute; top: 12px; right: 12px;
        background: var(--amber);
        color: var(--ink);
        font-size: 10px;
        font-weight: 500;
        padding: 3px 12px;
        border-radius: 50px;
        letter-spacing: 0.06em;
    }
    .prod-body { padding: 20px 18px; }
    .prod-body h5 { font-size: 14px; font-weight: 500; color: var(--ink); margin-bottom: 5px; }
    .prod-desc { font-size: 12px; color: var(--muted); line-height: 1.5; margin-bottom: 14px; font-weight: 300; }
    .prod-price {
        font-family: 'Cormorant Garamond', serif;
        font-size: 1.5rem;
        font-weight: 700;
        color: var(--teal-mid);
    }
    .btn-add-cart {
        width: 100%;
        margin-top: 12px;
        background: var(--teal-deep);
        color: #fff;
        border: none;
        border-radius: 12px;
        padding: 10px;
        font-size: 12px;
        font-family: 'DM Sans', sans-serif;
        font-weight: 500;
        cursor: pointer;
        transition: background 0.2s;
        letter-spacing: 0.03em;
    }
    .btn-add-cart:hover { background: var(--teal-mid); }

    /* ── TEAM ── */
    .team-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; margin-top: 52px; }
    .team-card {
        background: #fff;
        border-radius: 22px;
        padding: 38px 26px;
        text-align: center;
        border: 1px solid rgba(0,0,0,0.05);
    }
    .team-avatar {
        width: 76px; height: 76px;
        border-radius: 50%;
        background: var(--teal-light);
        margin: 0 auto 18px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-family: 'Cormorant Garamond', serif;
        font-size: 1.6rem;
        font-weight: 700;
        color: var(--teal-mid);
    }
    .team-card h4 { font-size: 16px; font-weight: 500; color: var(--ink); margin-bottom: 5px; }
    .team-card p { font-size: 13px; color: var(--muted); font-weight: 300; }
    .team-tag {
        margin-top: 14px;
        display: inline-block;
        font-size: 11px;
        font-weight: 500;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        background: var(--teal-light);
        color: var(--teal-mid);
        padding: 5px 16px;
        border-radius: 50px;
    }

    /* ── CONTACT ── */
    .contact-inner { display: grid; grid-template-columns: 1fr 1fr; gap: 64px; align-items: start; margin-top: 56px; }
    .contact-info-item {
        display: flex; align-items: center; gap: 16px;
        padding: 20px 0;
        border-bottom: 1px solid rgba(255,255,255,0.08);
    }
    .contact-info-item:last-child { border-bottom: none; }
    .ci-icon {
        width: 44px; height: 44px; border-radius: 13px;
        background: rgba(26,167,164,0.15);
        display: flex; align-items: center; justify-content: center; flex-shrink: 0;
    }
    .ci-icon svg { width: 18px; height: 18px; stroke: var(--teal-bright); stroke-width: 1.8; fill: none; }
    .ci-label { font-size: 11px; color: rgba(255,255,255,0.4); letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: 3px; }
    .ci-val { font-size: 14px; color: #fff; }

    .contact-form-wrap {
        background: rgba(255,255,255,0.05);
        border: 1px solid rgba(255,255,255,0.1);
        border-radius: 22px;
        padding: 36px;
    }
    .cf-field { margin-bottom: 16px; }
    .cf-field input, .cf-field textarea {
        width: 100%;
        background: rgba(255,255,255,0.06);
        border: 1px solid rgba(255,255,255,0.12);
        border-radius: 12px;
        padding: 14px 18px;
        color: #fff;
        font-family: 'DM Sans', sans-serif;
        font-size: 14px;
        outline: none;
        transition: border-color 0.2s;
    }
    .cf-field input::placeholder, .cf-field textarea::placeholder { color: rgba(255,255,255,0.3); }
    .cf-field input:focus, .cf-field textarea:focus { border-color: rgba(26,167,164,0.5); }
    .cf-field textarea { resize: none; }
    .cf-submit {
        width: 100%;
        background: var(--amber);
        color: var(--ink);
        border: none;
        border-radius: 12px;
        padding: 15px;
        font-family: 'DM Sans', sans-serif;
        font-size: 14px;
        font-weight: 500;
        cursor: pointer;
        transition: background 0.2s;
    }
    .cf-submit:hover { background: #f5b040; }

    /* ── FOOTER ── */
    .sf-footer {
        background: var(--ink);
        padding: 36px 40px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 20px;
    }
    .footer-logo {
        font-family: 'Cormorant Garamond', serif;
        font-size: 1.6rem;
        font-weight: 700;
        color: #fff;
    }
    .footer-logo span { color: var(--amber); }
    .footer-copy { font-size: 12px; color: rgba(255,255,255,0.3); }

    /* ── CART MODAL ── */
    .modal-content { border-radius: 20px; border: none; }
    .modal-header { border-bottom: 1px solid rgba(0,0,0,0.06); padding: 20px 24px; }
    .modal-body { padding: 24px; }
    .modal-footer { border-top: 1px solid rgba(0,0,0,0.06); padding: 16px 24px; }

    /* ── RESPONSIVE ── */
    @media (max-width: 768px) {
        .about-grid, .contact-inner { grid-template-columns: 1fr; }
        .services-grid, .team-grid { grid-template-columns: 1fr 1fr; }
        .products-grid { grid-template-columns: 1fr 1fr; }
        .stats-grid { grid-template-columns: 1fr 1fr; }
        .offer-strip { flex-direction: column; text-align: center; margin: 0 20px; padding: 36px 28px; }
        .sf-section, .sf-section-sm { padding: 60px 24px; }
        .hero { padding: 70px 24px 100px; }
    }

    @media (max-width: 480px) {
        .services-grid, .team-grid, .products-grid { grid-template-columns: 1fr; }
    }
</style>
{% endblock %}

{% block body %}

<!-- HERO -->
<div class="hero">
    <div class="hero-orb hero-orb-1"></div>
    <div class="hero-orb hero-orb-2"></div>
    <div class="hero-orb hero-orb-3"></div>
    <div class="hero-wave-top"></div>

    <div class="hero-eyebrow">Ocean-to-Table · Dumaguete City, PH</div>
    <h1>The <em>freshest</em><br>catch on your<br>doorstep.</h1>
    <p class="hero-sub">Sustainably sourced seafood — delivered in under 2 hours, every time.</p>

    <div style="display:flex;flex-wrap:wrap;justify-content:center;gap:0;">
        {% if app.user %}
            <a href="{{ path('app_dashboard') }}" class="btn-primary-sf">
                Go to Dashboard <i class="fas fa-arrow-right"></i>
            </a>
        {% else %}
            <a href="{{ path('app_login') }}" class="btn-primary-sf">
                Order Now <i class="fas fa-arrow-right"></i>
            </a>
            <a href="#about" class="btn-ghost-sf">Learn More</a>
        {% endif %}
    </div>

    <div class="hero-scroll-indicator">
        <div class="scroll-dot"></div>
        <div class="scroll-dot"></div>
        <div class="scroll-dot"></div>
    </div>
</div>

<!-- MARQUEE BAND -->
<div class="marquee-band">
    <div class="marquee-track">
        <span class="marquee-item">Fresh Daily Catch <span class="marquee-dot"></span></span>
        <span class="marquee-item">Free Delivery on ₱999+ <span class="marquee-dot"></span></span>
        <span class="marquee-item">15% Off First Order <span class="marquee-dot"></span></span>
        <span class="marquee-item">Eco-Friendly Packaging <span class="marquee-dot"></span></span>
        <span class="marquee-item">24/7 Support <span class="marquee-dot"></span></span>
        <span class="marquee-item">100% Traceable Sources <span class="marquee-dot"></span></span>
        <span class="marquee-item">Fresh Daily Catch <span class="marquee-dot"></span></span>
        <span class="marquee-item">Free Delivery on ₱999+ <span class="marquee-dot"></span></span>
        <span class="marquee-item">15% Off First Order <span class="marquee-dot"></span></span>
        <span class="marquee-item">Eco-Friendly Packaging <span class="marquee-dot"></span></span>
        <span class="marquee-item">24/7 Support <span class="marquee-dot"></span></span>
        <span class="marquee-item">100% Traceable Sources <span class="marquee-dot"></span></span>
    </div>
</div>

<!-- ABOUT -->
<section id="about" class="sf-section">
    <span class="section-tag">About Seafoodie</span>
    <div class="about-grid">
        <div>
            <h2 class="section-h">Pure catch,<br><em>no compromise.</em></h2>
            <p class="section-lead">We partner with local fishermen and sustainable farms across Dumaguete to bring you the highest quality seafood — handled with care from net to your kitchen.</p>
            <div class="about-checks">
                <div class="check-item">
                    <div class="check-icon">
                        <svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg>
                    </div>
                    <div>
                        <div class="check-title">24h ocean-to-table promise</div>
                        <div class="check-desc">From boat to your door, same day.</div>
                    </div>
                </div>
                <div class="check-item">
                    <div class="check-icon">
                        <svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg>
                    </div>
                    <div>
                        <div class="check-title">100% traceable sources</div>
                        <div class="check-desc">Know exactly where your seafood comes from.</div>
                    </div>
                </div>
                <div class="check-item">
                    <div class="check-icon">
                        <svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg>
                    </div>
                    <div>
                        <div class="check-title">Eco-friendly packaging</div>
                        <div class="check-desc">Recyclable, biodegradable materials throughout.</div>
                    </div>
                </div>
            </div>
        </div>
        <div class="stats-grid">
            <div class="stat-card">
                <div class="stat-num">500+</div>
                <div class="stat-label">Happy Deliveries</div>
            </div>
            <div class="stat-card">
                <div class="stat-num">4.9</div>
                <div class="stat-label">Customer Rating</div>
            </div>
            <div class="stat-card">
                <div class="stat-num">24/7</div>
                <div class="stat-label">Support</div>
            </div>
            <div class="stat-card">
                <div class="stat-num">15+</div>
                <div class="stat-label">Varieties</div>
            </div>
        </div>
    </div>
</section>

<!-- OFFER STRIP -->
<div class="offer-strip">
    <div>
        <div class="offer-pill">Limited Time</div>
        <h3>Fresh Deals,<br>Every Single Day.</h3>
        <p>15% off your first order + free delivery when you spend ₱999 or more.</p>
    </div>
    {% if app.user %}
        <a href="{{ path('app_dashboard') }}" class="offer-btn">Shop Now &rarr;</a>
    {% else %}
        <a href="{{ path('app_login') }}" class="offer-btn">Claim Offer &rarr;</a>
    {% endif %}
</div>

<!-- SERVICES -->
