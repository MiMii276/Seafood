{% extends 'base.html.twig' %}

{% block title %}Products - Seafoodie{% endblock %}

{% block stylesheets %}
{{ parent() }}
<style>
    /* ========================================
       COMPACT PREMIUM PRODUCTS TABLE DESIGN
       ======================================== */
    
    @import url('https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,400;14..32,500;14..32,600;14..32,700&display=swap');
    
    body {
        font-family: 'Inter', sans-serif;
        background: linear-gradient(135deg, #f5f7fc 0%, #eef2f8 100%);
        min-height: 100vh;
    }
    
    /* Hide footer */
    .footer {
        display: none !important;
    }
    
    /* Main Wrapper */
    .products-wrapper {
        padding: 1.5rem;
        min-height: 90vh;
    }
    
    /* Premium Card */
    .products-card {
        background: white;
        border-radius: 1.5rem;
        box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.1);
        overflow: hidden;
    }
    
    /* Premium Header */
    .products-header {
        background: linear-gradient(135deg, #0a2b2e, #1f7a8c);
        padding: 1.25rem 1.5rem;
        position: relative;
    }
    
    .products-header::after {
        content: '';
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        height: 3px;
        background: linear-gradient(90deg, #f4a942, #1f7a8c, #f4a942);
    }
    
    .header-title {
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }
    
    .header-icon {
        width: 40px;
        height: 40px;
        background: rgba(255,255,255,0.12);
        border-radius: 0.75rem;
        display: flex;
        align-items: center;
        justify-content: center;
    }
    
    .header-icon i {
        font-size: 1.2rem;
        color: white;
    }
    
    .products-header h1 {
        color: white;
        font-size: 1.3rem;
        font-weight: 700;
        margin: 0;
        letter-spacing: -0.3px;
    }
    
    .products-header p {
        color: rgba(255,255,255,0.7);
        font-size: 0.7rem;
        margin: 0.25rem 0 0;
    }
    
    /* Content Body */
    .products-body {
        padding: 1.5rem;
    }
    
    /* Top Controls */
    .top-controls {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 1rem;
        margin-bottom: 1.5rem;
        flex-wrap: wrap;
    }
    
    .btn-create {
        background: linear-gradient(135deg, #1f7a8c, #0a5c6b);
        color: white;
        border: none;
        padding: 0.6rem 1.2rem;
        border-radius: 2rem;
        font-weight: 600;
        font-size: 0.8rem;
        transition: all 0.2s ease;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
    }
    
    .btn-create:hover {
        transform: translateY(-1px);
        box-shadow: 0 6px 14px -6px rgba(31, 122, 140, 0.4);
        color: white;
        text-decoration: none;
    }
    
    .btn-dashboard {
        background: transparent;
        color: #1f7a8c;
        border: 1.5px solid #1f7a8c;
        padding: 0.6rem 1.2rem;
        border-radius: 2rem;
        font-weight: 600;
        font-size: 0.8rem;
        transition: all 0.2s ease;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
    }
    
    .btn-dashboard:hover {
        background: #1f7a8c;
        color: white;
        transform: translateY(-1px);
        box-shadow: 0 6px 14px -6px rgba(31, 122, 140, 0.4);
        text-decoration: none;
    }
    
    .search-form {
        display: flex;
        gap: 0.5rem;
    }
    
    .search-input {
        padding: 0.6rem 1rem;
        border: 1.5px solid #e2e8f0;
        border-radius: 2rem;
        font-size: 0.8rem;
        width: 250px;
        transition: all 0.2s ease;
    }
    
    .search-input:focus {
        outline: none;
        border-color: #1f7a8c;
        box-shadow: 0 0 0 3px rgba(31, 122, 140, 0.1);
    }
    
    .btn-search {
        background: linear-gradient(135deg, #1f7a8c, #0a5c6b);
        color: white;
        border: none;
        padding: 0.6rem 1.2rem;
        border-radius: 2rem;
        font-weight: 600;
        font-size: 0.8rem;
        transition: all 0.2s ease;
        cursor: pointer;
    }
    
    .btn-search:hover {
        transform: translateY(-1px);
        box-shadow: 0 6px 14px -6px rgba(31, 122, 140, 0.4);
    }
    
    /* Button Group */
    .button-group {
        display: flex;
        gap: 0.75rem;
        align-items: center;
    }
    
    /* Table Styles */
    .table-responsive {
        overflow-x: auto;
    }
    
    .product-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 0.8rem;
    }
    
    .product-table th {
        background: #f8fafc;
        padding: 0.9rem 0.8rem;
        font-size: 0.7rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        color: #64748b;
        border-bottom: 2px solid #e2e8f0;
        text-align: left;
    }
    
    .product-table td {
        padding: 0.8rem;
        border-bottom: 1px solid #f0f2f5;
        vertical-align: middle;
    }
    
    .product-table tbody tr {
        transition: all 0.2s ease;
    }
    
    .product-table tbody tr:hover {
        background: rgba(31, 122, 140, 0.04);
    }
    
    /* Price Badge */
    .price-badge {
        background: linear-gradient(135deg, #f4a94220, #f4a94210);
        padding: 0.2rem 0.6rem;
        border-radius: 2rem;
        display: inline-block;
        font-size: 0.8rem;
        font-weight: 700;
        color: #f4a942;
    }
    
    /* Stock Badge */
    .stock-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.3rem;
        padding: 0.2rem 0.6rem;
        border-radius: 2rem;
        font-size: 0.7rem;
        font-weight: 600;
    }
    
    .stock-high {
        background: #d1fae5;
        color: #065f46;
    }
    
    .stock-medium {
        background: #fed7aa;
        color: #9a3412;
    }
    
    .stock-low {
        background: #fee2e2;
        color: #b91c1c;
    }
    
    /* Action Buttons */
    .action-group {
        display: flex;
        gap: 0.3rem;
        justify-content: center;
        flex-wrap: wrap;
    }
    
    .btn-view {
        background: #e0f2fe;
        color: #0284c7;
        border: none;
        padding: 0.3rem 0.7rem;
        border-radius: 0.5rem;
        font-size: 0.7rem;
        font-weight: 600;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 0.2rem;
        transition: all 0.2s ease;
    }
    
    .btn-view:hover {
        background: #0284c7;
        color: white;
        transform: translateY(-1px);
    }
    
    .btn-edit {
        background: #fed7aa;
        color: #c2410c;
        border: none;
        padding: 0.3rem 0.7rem;
        border-radius: 0.5rem;
        font-size: 0.7rem;
        font-weight: 600;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 0.2rem;
        transition: all 0.2s ease;
    }
    
    .btn-edit:hover {
        background: #c2410c;
        color: white;
        transform: translateY(-1px);
    }
    
    .btn-delete {
        background: #fee2e2;
        color: #dc2626;
        border: none;
        padding: 0.3rem 0.7rem;
        border-radius: 0.5rem;
        font-size: 0.7rem;
        font-weight: 600;
        display: inline-flex;
        align-items: center;
        gap: 0.2rem;
        transition: all 0.2s ease;
        cursor: pointer;
    }
    
    .btn-delete:hover {
        background: #dc2626;
        color: white;
        transform: translateY(-1px);
    }
    
    /* Empty State */
    .empty-state {
        text-align: center;
        padding: 3rem;
    }
    
    .empty-state i {
        font-size: 3rem;
        color: #cbd5e1;
        margin-bottom: 1rem;
    }
    
    .empty-state p {
        color: #64748b;
        margin-bottom: 1rem;
    }
    
    /* Responsive */
    @media (max-width: 768px) {
        .products-wrapper {
            padding: 1rem;
        }
        .products-body {
            padding: 1rem;
        }
        .top-controls {
            flex-direction: column;
            align-items: stretch;
        }
        .button-group {
            flex-direction: column;
            width: 100%;
        }
        .btn-create, .btn-dashboard {
            justify-content: center;
        }
        .search-form {
            width: 100%;
        }
        .search-input {
            flex: 1;
        }
        .product-table th,
        .product-table td {
            padding: 0.5rem;
        }
        .action-group {
            flex-direction: column;
            align-items: center;
        }
    }
</style>
{% endblock %}

{% block body %}
<div class="products-wrapper">
    <div class="products-card">
        <div class="products-header">
            <div class="header-title">
                <div class="header-icon">
                    <i class="fas fa-fish"></i>
                </div>
                <div>
                    <h1>Products</h1>
                    <p>Manage your seafood product inventory</p>
                </div>
            </div>
        </div>

        <div class="products-body">
            <!-- Top Controls -->
            <div class="top-controls">
                <div class="button-group">
                    <a href="{{ path('app_dashboard') }}" class="btn-dashboard">
                        <i class="fas fa-chart-line"></i> Dashboard
                    </a>
                    <a href="{{ path('app_product_new') }}" class="btn-create">
                        <i class="fas fa-plus-circle"></i> New Product
                    </a>
                </div>
                
                <form method="get" class="search-form">
                    <input type="text" name="search" value="{{ app.request.get('search') }}" 
                           class="search-input" placeholder="🔍 Search products...">
                    <button type="submit" class="btn-search">
                        <i class="fas fa-search"></i>
                    </button>
                </form>
            </div>

            <!-- Products Table -->
            <div class="table-responsive">
                <table class="product-table">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Product</th>
                            <th>Price</th>
                            <th>Stock</th>
                            <th>Created</th>
                            <th class="text-center">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for product in products %}
                            <tr>
                                <td style="color: #64748b; font-weight: 500;">#{{ product.id }}</td>
                                <td>
                                    <div>
                                        <div style="font-weight: 600; margin-bottom: 0.2rem;">{{ product.name }}</div>
                                        <div style="font-size: 0.7rem; color: #94a3b8;">{{ product.description ? product.description|slice(0, 50) ~ (product.description|length > 50 ? '...' : '') : '—' }}</div>
                                    </div>
                                </td>
                                <td>
                                    <span class="price-badge">₱{{ product.price|number_format(2) }}</span>
                                </td>
                                <td>
                                    {% if product.stock > 50 %}
                                        <span class="stock-badge stock-high">
                                            <i class="fas fa-check-circle"></i> {{ product.stock }}
                                        </span>
                                    {% elseif product.stock > 10 %}
                                        <span class="stock-badge stock-medium">
                                            <i class="fas fa-exclamation-triangle"></i> {{ product.stock }}
                                        </span>
                                    {% elseif product.stock > 0 %}
                                        <span class="stock-badge stock-low">
                                            <i class="fas fa-times-circle"></i> {{ product.stock }}
                                        </span>
                                    {% else %}
                                        <span class="stock-badge stock-low">
                                            <i class="fas fa-ban"></i> Out of stock
                                        </span>
                                    {% endif %}
                                </td>
                                <td style="font-size: 0.7rem; color: #64748b;">
                                    <i class="far fa-calendar-alt me-1"></i>
                                    {{ product.createdAt|date('M d, Y') }}
                                    <br>
                                    <i class="far fa-clock me-1"></i>
                                    {{ product.createdAt|date('h:i A') }}
                                </td>
                                <td class="text-center">
                                    <div class="action-group">
                                        <a href="{{ path('app_product_show', {'id': product.id}) }}" class="btn-view" title="View">
                                            <i class="fas fa-eye"></i>
                                        </a>
                                        
                                        {% set canEdit = product.createdBy.id == app.user.id or is_granted('ROLE_ADMIN') %}
                                        {% if canEdit %}
                                            <a href="{{ path('app_product_edit', {'id': product.id}) }}" class="btn-edit" title="Edit">
                                                <i class="fas fa-edit"></i>
                                            </a>
                                            <form method="post" action="{{ path('app_product_delete', {'id': product.id}) }}" 
                                                  onsubmit="return confirm('⚠️ Delete {{ product.name }}? This cannot be undone!');" style="display: inline;">
                                                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ product.id) }}">
                                                <button class="btn-delete" title="Delete">
                                                    <i class="fas fa-trash-alt"></i>
                                                </button>
                                            </form>
                                        {% endif %}
                                    </div>
                                </td>
                            </tr>
                        {% else %}
                            <tr>
                                <td colspan="6">
                                    <div class="empty-state">
                                        <i class="fas fa-fish"></i>
                                        <p>No products found.</p>
                                        <a href="{{ path('app_product_new') }}" class="btn-create">Create your first product</a>
                                    </div>
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
{% endblock %}