{% extends 'base.html.twig' %}

{% block title %}Fresh Seafood Products - Shop Today{% endblock %}

{% block stylesheets %}
{{ parent() }}
<style>
    * { box-sizing: border-box; }

    :root {
        --teal-deep: #073B3A;
        --teal-mid: #0D6E6C;
        --teal-bright: #1AA7A4;
        --teal-light: #C8EFEE;
        --amber: #E8A030;
        --cream: #FAF8F3;
        --sand: #EFE9D9;
        --ink: #0D1F1E;
        --muted: #556B6A;
    }

    body {
        background: var(--cream);
        font-family: 'DM Sans', sans-serif;
    }

    /* ── PAGE HEADER ── */
    .page-header {
        background: var(--teal-deep);
        color: #fff;
        padding: 120px 40px 60px;
        text-align: center;
        margin-top: -56px;
    }

    .page-header h1 {
        font-family: 'Cormorant Garamond', serif;
        font-size: clamp(2.5rem, 5vw, 4rem);
        font-weight: 700;
        line-height: 1.1;
        margin-bottom: 20px;
    }

    .page-header p {
        font-size: 16px;
        color: rgba(255,255,255,0.7);
        max-width: 600px;
        margin: 0 auto;
    }

    /* ── SECTION SHELL ── */
    .sf-section { padding: 90px 40px; }

    .section-tag {
        font-size: 11px;
        font-weight: 500;
        letter-spacing: 0.16em;
        text-transform: uppercase;
        color: var(--teal-bright);
        display: block;
        margin-bottom: 14px;
    }

    .section-h {
        font-family: 'Cormorant Garamond', serif;
        font-size: clamp(2.2rem, 4vw, 3.2rem);
        font-weight: 700;
        color: var(--ink);
        line-height: 1.1;
    }

    .section-h em { font-style: italic; color: var(--teal-mid); }

    .section-lead {
        font-size: 15px;
        color: var(--muted);
        margin-top: 12px;
        font-weight: 300;
        line-height: 1.75;
        max-width: 540px;
    }

    /* ── PRODUCTS ── */
    .products-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; margin-top: 52px; }
    
    .prod-card {
        background: #fff;
        border-radius: 22px;
        overflow: hidden;
        border: 1px solid rgba(0,0,0,0.05);
        transition: transform 0.25s, box-shadow 0.25s;
    }
    
    .prod-card:hover { transform: translateY(-6px); box-shadow: 0 16px 36px rgba(7,59,58,0.1); }
    
    .prod-top {
        background: var(--teal-light);
        height: 120px;
        display: flex; align-items: center; justify-content: center;
        font-size: 48px;
        position: relative;
    }
    
    .prod-badge {
        position: absolute; top: 12px; right: 12px;
        background: var(--amber);
        color: var(--ink);
        font-size: 10px;
        font-weight: 500;
        padding: 3px 12px;
        border-radius: 50px;
        letter-spacing: 0.06em;
    }
    
    .prod-body { padding: 20px 18px; }
    .prod-body h5 { font-size: 14px; font-weight: 500; color: var(--ink); margin-bottom: 5px; }
    .prod-desc { font-size: 12px; color: var(--muted); line-height: 1.5; margin-bottom: 14px; font-weight: 300; }
    .prod-price {
        font-family: 'Cormorant Garamond', serif;
        font-size: 1.5rem;
        font-weight: 700;
        color: var(--teal-mid);
    }
    
    .btn-add-cart {
        width: 100%;
        margin-top: 12px;
        background: var(--teal-deep);
        color: #fff;
        border: none;
        border-radius: 12px;
        padding: 10px;
        font-size: 12px;
        font-family: 'DM Sans', sans-serif;
        font-weight: 500;
        cursor: pointer;
        transition: background 0.2s;
        letter-spacing: 0.03em;
        text-decoration: none;
        display: block;
        text-align: center;
    }
    
    .btn-add-cart:hover { background: var(--teal-mid); color: #fff; }

    .empty-state {
        grid-column: 1 / -1;
        text-align: center;
        padding: 60px 20px;
        color: var(--muted);
    }

    .empty-state-icon {
        font-size: 4rem;
        margin-bottom: 20px;
    }

    @media (max-width: 768px) {
        .products-grid { grid-template-columns: 1fr 1fr; }
        .page-header { padding: 80px 24px 40px; }
        .sf-section { padding: 60px 24px; }
    }

    @media (max-width: 480px) {
        .products-grid { grid-template-columns: 1fr; }
    }
</style>
{% endblock %}

{% block body %}

<!-- PAGE HEADER -->
<div class="page-header">
    <h1>Fresh Catch Today</h1>
    <p>Premium seafood — sourced this morning, at your door by noon</p>
</div>

<!-- PRODUCTS SECTION -->
<section class="sf-section">
    <span class="section-tag">Today's Fresh Picks</span>
    <h2 class="section-h">Catch of<br><em>the day.</em></h2>
    <p class="section-lead">Premium selection — sourced this morning, at your door by noon.</p>

    <div class="products-grid">
        {% if products is defined and products|length > 0 %}
            {% for product in products %}
                <div class="prod-card">
                    <div class="prod-top">
                        {% if 'prawn' in product.name|lower %}🦐
                        {% elseif 'lobster' in product.name|lower %}🦞
                        {% elseif 'fish' in product.name|lower or 'lapu' in product.name|lower %}🐟
                        {% elseif 'squid' in product.name|lower %}🦑
                        {% elseif 'crab' in product.name|lower %}🦀
                        {% else %}🐠
                        {% endif %}
                        {% if loop.first %}<span class="prod-badge">Popular</span>{% endif %}
                    </div>
                    <div class="prod-body">
                        <h5>{{ product.name }}</h5>
                        <p class="prod-desc">{{ product.description|slice(0, 55) }}</p>
                        <div class="prod-price">₱{{ product.price|number_format(2) }}</div>
                        {% if app.user %}
                            <button class="btn-add-cart add-to-cart"
                                    data-product="{{ product.name }}"
                                    data-price="{{ product.price }}">
                                <i class="fas fa-cart-plus"></i> Add to Cart
                            </button>
                        {% else %}
                            <a href="{{ path('app_login') }}" class="btn-add-cart">
                                <i class="fas fa-lock"></i> Login to Order
                            </a>
                        {% endif %}
                    </div>
                </div>
            {% endfor %}
        {% else %}
            <div class="empty-state">
                <div class="empty-state-icon">🦐</div>
                <h4>No products available yet</h4>
                <p>Check back soon for fresh daily catches!</p>
            </div>
        {% endif %}
    </div>
</section>

{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
{% if app.user %}
let cart = [];

function addToCart(product, price) {
    cart.push({ product, price });
    updateCartDisplay();
    showToast(product + ' added to cart!');
}

function showToast(msg) {
    const t = document.createElement('div');
    t.textContent = msg;
    t.style.cssText = 'position:fixed;bottom:30px;right:30px;background:#0D6E6C;color:#fff;padding:12px 24px;border-radius:50px;font-family:DM Sans,sans-serif;font-size:14px;z-index:9999;transition:opacity 0.4s;box-shadow:0 8px 24px rgba(0,0,0,0.15)';
    document.body.appendChild(t);
    setTimeout(() => { t.style.opacity = '0'; setTimeout(() => t.remove(), 400); }, 2200);
}

function updateCartDisplay() {
    const cartItemsDiv = document.getElementById('cartItems');
    const cartTotalSpan = document.getElementById('cartTotal');
    if (!cartItemsDiv) return;
    if (cart.length === 0) {
        cartItemsDiv.innerHTML = '<p class="text-muted">Your cart is empty</p>';
        if (cartTotalSpan) cartTotalSpan.textContent = '0.00';
        return;
    }
    let total = 0;
    let html = '<div class="list-group">';
    cart.forEach((item, i) => {
        total += item.price;
        html += `<div class="list-group-item d-flex justify-content-between align-items-center">
            <span>${item.product}</span>
            <span class="fw-bold">₱${parseFloat(item.price).toFixed(2)}</span>
            <button class="btn btn-sm btn-outline-danger ms-2" onclick="removeFromCart(${i})">×</button>
        </div>`;
    });
    html += '</div>';
    cartItemsDiv.innerHTML = html;
    if (cartTotalSpan) cartTotalSpan.textContent = total.toFixed(2);
}

function removeFromCart(index) {
    cart.splice(index, 1);
    updateCartDisplay();
}

function checkout() {
    if (cart.length === 0) { alert('Your cart is empty!'); return; }
    const total = cart.reduce((s, i) => s + i.price, 0);
    alert('Order placed! Total: ₱' + total.toFixed(2) + '. Thank you for shopping with Seafoodie!');
    cart = [];
    updateCartDisplay();
    setTimeout(() => {
        const modal = bootstrap.Modal.getInstance(document.getElementById('cartModal'));
        if (modal) modal.hide();
    }, 1500);
}

document.querySelectorAll('.add-to-cart').forEach(btn => {
    btn.addEventListener('click', function() {
        addToCart(this.dataset.product, parseFloat(this.dataset.price));
    });
});
{% endif %}
</script>
{% endblock %}
