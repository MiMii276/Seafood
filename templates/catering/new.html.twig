{% extends 'base.html.twig' %}

{% block title %}New Catering Package - Seafoodie{% endblock %}

{% block stylesheets %}
{{ parent() }}
<style>
    /* ========================================
       ULTRA PREMIUM CATERING FORM DESIGN
       ======================================== */
    
    @import url('https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;14..32,400;14..32,500;14..32,600;14..32,700;14..32,800&family=Playfair+Display:wght@400;500;600;700;800&display=swap');
    
    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }
    
    body {
        font-family: 'Inter', sans-serif;
        background: linear-gradient(135deg, #f5f7fc 0%, #eef2f8 100%);
        min-height: 100vh;
    }
    
    /* Hide footer */
    .footer {
        display: none !important;
    }
    
    /* Main Wrapper */
    .catering-wrapper {
        min-height: 90vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 2rem 1.5rem;
    }
    
    /* Premium Card */
    .catering-card {
        background: rgba(255,255,255,0.98);
        backdrop-filter: blur(10px);
        border-radius: 2rem;
        box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25);
        max-width: 750px;
        width: 100%;
        overflow: hidden;
        animation: slideUp 0.5s ease;
        transition: all 0.3s ease;
        border: 1px solid rgba(255,255,255,0.3);
    }
    
    @keyframes slideUp {
        from {
            opacity: 0;
            transform: translateY(30px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
    
    /* Premium Header */
    .catering-header {
        background: linear-gradient(135deg, #0a2b2e 0%, #1a6b7a 50%, #0f2e3a 100%);
        padding: 2rem;
        position: relative;
        overflow: hidden;
        text-align: center;
    }
    
    .catering-header::before {
        content: '';
        position: absolute;
        top: -50%;
        left: -50%;
        width: 200%;
        height: 200%;
        background: radial-gradient(circle, rgba(255,255,255,0.08) 1px, transparent 1px);
        background-size: 40px 40px;
        animation: slowDrift 60s linear infinite;
    }
    
    @keyframes slowDrift {
        0% { transform: translate(0, 0); }
        100% { transform: translate(40px, 40px); }
    }
    
    .catering-header::after {
        content: '';
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        height: 4px;
        background: linear-gradient(90deg, #f4a942, #1f7a8c, #f4a942, #1f7a8c);
        background-size: 300% 100%;
        animation: gradientShift 4s ease infinite;
    }
    
    @keyframes gradientShift {
        0% { background-position: 0% 50%; }
        50% { background-position: 100% 50%; }
        100% { background-position: 0% 50%; }
    }
    
    .header-icon {
        width: 80px;
        height: 80px;
        background: rgba(255,255,255,0.12);
        backdrop-filter: blur(10px);
        border-radius: 1.5rem;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 1rem;
        border: 1px solid rgba(255,255,255,0.25);
        transition: all 0.3s ease;
    }
    
    .catering-card:hover .header-icon {
        transform: scale(1.05);
        background: rgba(255,255,255,0.18);
    }
    
    .header-icon i {
        font-size: 2.2rem;
        color: white;
    }
    
    .catering-header h1 {
        color: white;
        font-size: 1.85rem;
        font-weight: 800;
        margin: 0;
        letter-spacing: -0.3px;
        font-family: 'Playfair Display', serif;
        background: linear-gradient(135deg, #fff, #e0f2fe, #f4a942);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
    }
    
    .catering-header p {
        color: rgba(255,255,255,0.8);
        font-size: 0.85rem;
        margin: 0.5rem 0 0;
    }
    
    /* Form Body */
    .form-body {
        padding: 2rem;
    }
    
    /* Form Groups */
    .form-group {
        margin-bottom: 1.5rem;
    }
    
    .form-label {
        font-size: 0.75rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: #64748b;
        margin-bottom: 0.5rem;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }
    
    .form-label i {
        font-size: 0.8rem;
        color: #1f7a8c;
    }
    
    .form-control, .form-select {
        width: 100%;
        padding: 0.85rem 1rem;
        font-size: 0.9rem;
        border: 2px solid #e2e8f0;
        border-radius: 1rem;
        transition: all 0.2s ease;
        background: #ffffff;
        font-family: 'Inter', sans-serif;
    }
    
    .form-control:focus, .form-select:focus {
        outline: none;
        border-color: #1f7a8c;
        box-shadow: 0 0 0 4px rgba(31, 122, 140, 0.1);
    }
    
    textarea.form-control {
        resize: vertical;
        min-height: 100px;
    }
    
    /* Multiple Select Styling */
    select[multiple] {
        min-height: 150px;
        padding: 0.5rem;
    }
    
    select[multiple] option {
        padding: 0.6rem 0.8rem;
        border-radius: 0.5rem;
        margin-bottom: 0.25rem;
        cursor: pointer;
    }
    
    select[multiple] option:checked {
        background: linear-gradient(135deg, #1f7a8c, #0a5c6b);
        color: white;
    }
    
    /* Error Styling */
    .form-error {
        color: #dc2626;
        font-size: 0.7rem;
        margin-top: 0.5rem;
        display: flex;
        align-items: center;
        gap: 0.25rem;
        padding-left: 0.5rem;
    }
    
    .form-error i {
        font-size: 0.7rem;
    }
    
    /* Action Buttons */
    .action-buttons {
        display: flex;
        gap: 1rem;
        margin-top: 1.5rem;
        padding-top: 1rem;
    }
    
    .btn-create {
        flex: 1;
        background: linear-gradient(135deg, #1f7a8c, #0a5c6b);
        color: white;
        border: none;
        padding: 0.9rem;
        border-radius: 3rem;
        font-weight: 700;
        font-size: 0.9rem;
        transition: all 0.3s cubic-bezier(0.2, 0.85, 0.4, 1);
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 0.6rem;
        cursor: pointer;
        position: relative;
        overflow: hidden;
    }
    
    .btn-create::before {
        content: '';
        position: absolute;
        top: 50%;
        left: 50%;
        width: 0;
        height: 0;
        border-radius: 50%;
        background: rgba(255,255,255,0.2);
        transform: translate(-50%, -50%);
        transition: width 0.6s, height 0.6s;
    }
    
    .btn-create:hover::before {
        width: 300px;
        height: 300px;
    }
    
    .btn-create:hover {
        transform: translateY(-2px);
        box-shadow: 0 12px 25px -8px rgba(31, 122, 140, 0.4);
    }
    
    .btn-back {
        flex: 1;
        background: transparent;
        color: #64748b;
        border: 2px solid #e2e8f0;
        padding: 0.9rem;
        border-radius: 3rem;
        font-weight: 700;
        font-size: 0.9rem;
        transition: all 0.2s ease;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
    }
    
    .btn-back:hover {
        background: #f8fafc;
        border-color: #1f7a8c;
        color: #1f7a8c;
        text-decoration: none;
        transform: translateY(-1px);
    }
    
    /* Price Input Group */
    .price-input-group {
        position: relative;
    }
    
    .price-input-group::before {
        content: '₱';
        position: absolute;
        left: 1rem;
        top: 50%;
        transform: translateY(-50%);
        color: #94a3b8;
        font-weight: 600;
        z-index: 1;
    }
    
    .price-input-group input {
        padding-left: 2rem;
    }
    
    /* Responsive */
    @media (max-width: 576px) {
        .catering-wrapper {
            padding: 1rem;
        }
        .catering-header {
            padding: 1.5rem;
        }
        .form-body {
            padding: 1.5rem;
        }
        .action-buttons {
            flex-direction: column;
        }
        .header-icon {
            width: 60px;
            height: 60px;
        }
        .header-icon i {
            font-size: 1.6rem;
        }
        .catering-header h1 {
            font-size: 1.4rem;
        }
    }
</style>
{% endblock %}

{% block body %}
<div class="catering-wrapper">
    <div class="catering-card">
        <div class="catering-header">
            <div class="header-icon">
                <i class="fas fa-utensils"></i>
            </div>
            <h1>Create Catering Package</h1>
            <p>Design a delicious catering experience for your clients</p>
        </div>

        <div class="form-body">
            {{ form_start(form) }}

            <!-- Package Name -->
            <div class="form-group">
                <div class="form-label">
                    <i class="fas fa-tag"></i>
                    <span>Package Name</span>
                </div>
                {{ form_widget(form.name, {'attr': {'class': 'form-control', 'placeholder': 'e.g., Seafood Feast Deluxe'}}) }}
                {% if form_errors(form.name) %}
                    <div class="form-error">
                        <i class="fas fa-exclamation-circle"></i>
                        {{ form_errors(form.name) }}
                    </div>
                {% endif %}
            </div>

            <!-- Description -->
            <div class="form-group">
                <div class="form-label">
                    <i class="fas fa-align-left"></i>
                    <span>Description</span>
                </div>
                {{ form_widget(form.description, {'attr': {'class': 'form-control', 'rows': 4, 'placeholder': 'Describe the catering package, what\'s included, etc.'}}) }}
                {% if form_errors(form.description) %}
                    <div class="form-error">
                        <i class="fas fa-exclamation-circle"></i>
                        {{ form_errors(form.description) }}
                    </div>
                {% endif %}
            </div>

            <!-- Event Date -->
            <div class="form-group">
                <div class="form-label">
                    <i class="fas fa-calendar-alt"></i>
                    <span>Event Date</span>
                </div>
                {{ form_widget(form.eventDate, {'attr': {'class': 'form-control'}}) }}
                {% if form_errors(form.eventDate) %}
                    <div class="form-error">
                        <i class="fas fa-exclamation-circle"></i>
                        {{ form_errors(form.eventDate) }}
                    </div>
                {% endif %}
            </div>

            <!-- Number of Guests -->
            <div class="form-group">
                <div class="form-label">
                    <i class="fas fa-users"></i>
                    <span>Number of Guests</span>
                </div>
                {{ form_widget(form.numberOfGuests, {'attr': {'class': 'form-control', 'placeholder': 'e.g., 50'}}) }}
                {% if form_errors(form.numberOfGuests) %}
                    <div class="form-error">
                        <i class="fas fa-exclamation-circle"></i>
                        {{ form_errors(form.numberOfGuests) }}
                    </div>
                {% endif %}
            </div>

            <!-- Price -->
            <div class="form-group">
                <div class="form-label">
                    <i class="fas fa-money-bill-wave"></i>
                    <span>Package Price</span>
                </div>
                <div class="price-input-group">
                    {{ form_widget(form.price, {'attr': {'class': 'form-control', 'placeholder': '0.00'}}) }}
                </div>
                {% if form_errors(form.price) %}
                    <div class="form-error">
                        <i class="fas fa-exclamation-circle"></i>
                        {{ form_errors(form.price) }}
                    </div>
                {% endif %}
            </div>

            <!-- Status -->
            <div class="form-group">
                <div class="form-label">
                    <i class="fas fa-circle"></i>
                    <span>Status</span>
                </div>
                {{ form_widget(form.status, {'attr': {'class': 'form-select'}}) }}
                {% if form_errors(form.status) %}
                    <div class="form-error">
                        <i class="fas fa-exclamation-circle"></i>
                        {{ form_errors(form.status) }}
                    </div>
                {% endif %}
            </div>

            <!-- Products (Multiple Select) -->
            <div class="form-group">
                <div class="form-label">
                    <i class="fas fa-fish"></i>
                    <span>Select Products</span>
                </div>
                {{ form_widget(form.products, {'attr': {'class': 'form-select', 'multiple': 'multiple', 'size': 6}}) }}
                <small class="text-muted mt-2 d-block">
                    <i class="fas fa-info-circle me-1"></i> Hold Ctrl (Windows) or Cmd (Mac) to select multiple products
                </small>
                {% if form_errors(form.products) %}
                    <div class="form-error">
                        <i class="fas fa-exclamation-circle"></i>
                        {{ form_errors(form.products) }}
                    </div>
                {% endif %}
            </div>

            <!-- Action Buttons -->
            <div class="action-buttons">
                <button type="submit" class="btn-create">
                    <i class="fas fa-plus-circle"></i> Create Package
                </button>
                <a href="{{ path('app_catering_index') }}" class="btn-back">
                    <i class="fas fa-arrow-left"></i> Back
                </a>
            </div>

            {{ form_end(form) }}
        </div>
    </div>
</div>
{% endblock %}